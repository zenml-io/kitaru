# Dev base image for testing kitaru flows on remote stacks (K8s, etc.).
#
# Builds from a clean Python image and installs ZenML (feature/kitaru
# branch) plus kitaru from the local source tree.
#
# Rebuild whenever kitaru or zenml dependencies change:
#   just dev-image
#
# Then reference the image in your flow:
#   @kitaru.flow(image={"base_image": "<ecr-url>:kitaru-dev"})

FROM python:3.12-slim-bookworm

# ZenML's image builder generates `uv pip install` commands without
# --system.  This env var makes uv default to system-level installs
# so those generated commands work in this venv-less image.
ENV UV_SYSTEM_PYTHON=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends git \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir --upgrade pip uv

# Install kitaru from local source.  Its pyproject.toml pulls
# zenml[local] from the feature/kitaru branch automatically.
COPY . /tmp/kitaru
RUN cd /tmp/kitaru && uv pip install . && rm -rf /tmp/kitaru

# Layer on cloud extras for remote artifact stores and connectors.
# Same git ref as above so uv recognizes the installed package and
# just adds the missing extras.
RUN uv pip install \
    "zenml[s3fs,gcsfs,adlfs,connectors-aws,connectors-gcp,connectors-azure] @ git+https://github.com/zenml-io/zenml.git@feature/kitaru"
