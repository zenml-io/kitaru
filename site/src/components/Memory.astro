---
// Memory.astro — "Agent Memory" section: code window + shelf visual + 4 bullet cards
---

<section id="memory" class="section-pad">
  <div class="section-inner">
    <span class="section-eyebrow" data-reveal>DURABLE MEMORY</span>
    <h2 class="section-title" data-reveal data-reveal-delay="1">
      State your agents can come back to.
    </h2>
    <p class="memory-subhead" data-reveal data-reveal-delay="2">
      Versioned, scoped memory across Python, CLI, and MCP &mdash; not a bolt-on scratchpad.
    </p>

    <div class="memory-grid">

      <div class="memory-code" data-reveal="fade-left" data-reveal-delay="3">
        <div class="memory-code-window">
          <div class="memory-code-header">
            <div class="memory-code-dots">
              <span class="code-dot"></span>
              <span class="code-dot"></span>
              <span class="code-dot"></span>
            </div>
            <span class="memory-code-filename">memory_demo.py</span>
          </div>
          <pre class="memory-code-pre code-syntax" aria-label="Kitaru memory API example"><code is:raw><span class="kw">from</span> kitaru <span class="kw">import</span> memory

memory.<span class="fn">configure</span>(
    scope<span class="op">=</span><span class="str">"my_repo"</span>,
    scope_type<span class="op">=</span><span class="str">"namespace"</span>,
)

<span class="cmt"># Store durable state</span>
memory.<span class="fn">set</span>(<span class="str">"conventions/test_runner"</span>, {
    <span class="str">"command"</span>: <span class="str">"just test"</span>,
    <span class="str">"notes"</span>: <span class="str">"Start targeted, then full suite."</span>,
})

<span class="cmt"># Next run — any surface — instant recall</span>
conventions <span class="op">=</span> memory.<span class="fn">get</span>(
    <span class="str">"conventions/test_runner"</span>
)</code></pre>
        </div>
      </div>

      <div class="memory-visual" data-reveal="fade-right" data-reveal-delay="4">
        <div class="shelf-container" id="memoryShelf">
          <div class="shelf-label">Memory Store</div>
          <div class="shelf-row" data-shelf="0">
            <div class="shelf-key">conventions/test_runner</div>
            <div class="shelf-versions">
              <span class="shelf-version shelf-faded">v1</span>
              <span class="shelf-version shelf-faded">v2</span>
              <span class="shelf-version shelf-latest">v3</span>
            </div>
          </div>
          <div class="shelf-row" data-shelf="1">
            <div class="shelf-key">sessions/topic_count</div>
            <div class="shelf-versions">
              <span class="shelf-version shelf-faded">v1</span>
              <span class="shelf-version shelf-latest">v2</span>
            </div>
          </div>
          <div class="shelf-row" data-shelf="2">
            <div class="shelf-key">scratch/obsolete</div>
            <div class="shelf-versions">
              <span class="shelf-version shelf-faded">v1</span>
              <span class="shelf-version shelf-tombstone">deleted</span>
            </div>
          </div>

          <div class="shelf-footer">
            <div class="shelf-indicator" id="shelfIndicator" aria-live="polite"></div>
            <div class="shelf-surfaces" id="shelfSurfaces">
              <span class="shelf-badge" data-surface="python">Python</span>
              <span class="shelf-badge" data-surface="cli">CLI</span>
              <span class="shelf-badge" data-surface="mcp">MCP</span>
            </div>
          </div>
        </div>
      </div>

    </div>

    <div class="memory-cards">
      <div class="memory-card" data-reveal="scale-up" data-reveal-delay="5">
        <div class="card-glow"></div>
        <div class="memory-card-inner">
          <div class="memory-card-label">Scopes</div>
          <h3>Scoped to your use case</h3>
          <p><code>namespace</code> for shared team state, <code>flow</code> for per-agent knowledge, <code>execution</code> for single-run scratch. Pick the right boundary.</p>
        </div>
      </div>

      <div class="memory-card" data-reveal="scale-up" data-reveal-delay="6">
        <div class="card-glow"></div>
        <div class="memory-card-inner">
          <div class="memory-card-label">Compaction</div>
          <h3>LLM-powered compaction</h3>
          <p>When memory grows, compact it: an LLM reads source entries and writes a concise summary as a new version. Sources stay intact &mdash; compaction is additive.</p>
        </div>
      </div>

      <div class="memory-card" data-reveal="scale-up" data-reveal-delay="7">
        <div class="card-glow"></div>
        <div class="memory-card-inner">
          <div class="memory-card-label">Audit</div>
          <h3>Audit trail built in</h3>
          <p>Every compaction and purge writes a <code>CompactionRecord</code> to a reserved audit log. Hard purge cleans old versions. You always know what happened.</p>
        </div>
      </div>

      <div class="memory-card" data-reveal="scale-up" data-reveal-delay="8">
        <div class="card-glow"></div>
        <div class="memory-card-inner">
          <div class="memory-card-label">Versioned</div>
          <h3>Versioned, not overwritten</h3>
          <p>Every <code>memory.set()</code> creates a new version. Deletes are soft &mdash; tombstones preserve the full history for audit and rollback.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ═══ Section ═══ */
  .memory-subhead {
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    font-weight: 300;
    line-height: 1.65;
    color: var(--color-secondary);
    max-width: 540px;
    margin-top: 12px;
    margin-bottom: 0;
  }

  /* ═══ Two-column grid ═══ */
  .memory-grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 32px;
    align-items: stretch;
    margin-top: 48px;
    margin-bottom: 48px;
  }

  /* ═══ Code window ═══ */
  .memory-code {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .memory-code-window {
    background: oklch(0.16 0.015 60);
    border: 1px solid oklch(1 0 0 / 0.08);
    border-radius: 12px;
    overflow: hidden;
  }

  .memory-code-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-bottom: 1px solid oklch(1 0 0 / 0.06);
  }

  .memory-code-dots {
    display: flex;
    gap: 6px;
  }

  .memory-code-filename {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: oklch(1 0 0 / 0.35);
  }

  .memory-code-pre {
    padding: 20px;
    margin: 0;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.7;
    color: var(--color-dark-text);
    -webkit-overflow-scrolling: touch;
  }

  /* ═══ Shelf visual ═══ */
  .memory-visual {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 320px;
  }

  .shelf-container {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .shelf-label {
    font-family: var(--font-mono);
    font-size: 0.63rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
    margin-bottom: 4px;
  }

  .shelf-row {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    background: oklch(1 0 0 / 0.6);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    overflow: hidden;
    transition: border-color 0.35s, box-shadow 0.35s;
  }

  .shelf-row.highlight {
    border-color: oklch(0.65 0.16 45 / 0.4);
    box-shadow: 0 0 0 3px oklch(0.65 0.16 45 / 0.07), 0 2px 8px oklch(0.65 0.16 45 / 0.06);
  }

  .shelf-key {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--color-primary);
    padding: 10px 14px 0;
    display: flex;
    align-items: center;
    font-weight: 600;
    white-space: nowrap;
    letter-spacing: -0.01em;
  }

  .shelf-versions {
    display: flex;
    gap: 6px;
    padding: 8px 14px 10px;
    align-items: center;
    flex-wrap: wrap;
  }

  .shelf-version {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    padding: 3px 10px;
    border-radius: 5px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-muted);
    transition: all 0.3s;
    white-space: nowrap;
  }

  .shelf-faded {
    opacity: 0.45;
  }

  .shelf-latest {
    border-color: oklch(0.65 0.16 45 / 0.4);
    background: oklch(0.65 0.16 45 / 0.08);
    color: var(--color-accent);
    font-weight: 600;
    opacity: 1;
  }

  .shelf-tombstone {
    text-decoration: line-through;
    opacity: 0.5;
    border-style: dashed;
    color: oklch(0.55 0.18 25);
    border-color: oklch(0.55 0.18 25 / 0.25);
  }

  .shelf-footer {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 14px 16px;
    margin-top: 6px;
    text-align: center;
  }

  .shelf-indicator {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: var(--color-accent);
    text-align: center;
    height: 20px;
    opacity: 0;
    transition: opacity 0.35s;
  }

  .shelf-indicator.visible {
    opacity: 1;
  }

  .shelf-surfaces {
    display: flex;
    gap: 6px;
    justify-content: center;
    margin-top: 8px;
    flex-wrap: wrap;
  }

  .shelf-badge {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    padding: 4px 12px;
    border-radius: 20px;
    background: var(--color-surface-warm);
    border: 1px solid var(--color-border);
    color: var(--color-muted);
    transition: all 0.35s;
  }

  .shelf-badge.active {
    border-color: oklch(0.65 0.16 45 / 0.4);
    color: var(--color-accent);
    background: oklch(0.65 0.16 45 / 0.07);
    box-shadow: 0 0 0 2px oklch(0.65 0.16 45 / 0.05);
  }

  /* ═══ Bullet cards ═══ */
  .memory-cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .memory-card {
    position: relative;
    overflow: hidden;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    transition: border-color 0.3s;
  }

  .memory-card:hover {
    border-color: oklch(0.65 0.16 45 / 0.25);
  }

  .memory-card:hover .card-glow {
    opacity: 1;
  }

  .memory-card-inner {
    position: relative;
    z-index: 2;
    padding: 24px;
  }

  .memory-card-label {
    font-family: var(--font-mono);
    font-size: 0.63rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 10px;
  }

  .memory-card h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
    line-height: 1.3;
    color: var(--color-primary);
  }

  .memory-card p {
    color: var(--color-secondary);
    font-size: 0.83rem;
    line-height: 1.6;
    font-weight: 300;
  }

  .memory-card code {
    font-family: var(--font-mono);
    font-size: 0.78em;
    color: var(--color-accent);
    background: oklch(0.65 0.16 45 / 0.06);
    padding: 1px 5px;
    border-radius: 3px;
  }

  /* ═══ Responsive ═══ */
  @media (max-width: 768px) {
    .memory-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .memory-cards {
      grid-template-columns: 1fr;
    }

    .memory-code-window {
      position: relative;
    }

    .memory-code-window::after {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      bottom: 0;
      width: 32px;
      background: linear-gradient(90deg, transparent, oklch(0.16 0.015 60));
      pointer-events: none;
      border-radius: 0 12px 12px 0;
    }

    .shelf-key {
      font-size: 0.62rem;
    }
  }

  @media (max-width: 480px) {
    .memory-code-pre {
      font-size: 0.72rem;
      padding: 16px;
    }

    .memory-card-inner {
      padding: 20px;
    }

    .memory-card h3 {
      font-size: 0.9rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .shelf-row,
    .shelf-badge,
    .shelf-indicator,
    .shelf-version {
      transition: none;
    }
  }
</style>

<script>
  import { setupCardGlow } from '../scripts/card-glow';
  setupCardGlow('#memory .memory-card');

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    const shelf = document.getElementById('memoryShelf');
    if (shelf) {
      const rows = shelf.querySelectorAll<HTMLElement>('.shelf-row');
      const indicator = document.getElementById('shelfIndicator');
      const badges = shelf.querySelectorAll<HTMLElement>('.shelf-badge');

      const steps = [
        { row: 0, surface: 0, label: '\u2192 memory.get("conventions/test_runner") \u2192 v3' },
        { row: 1, surface: 1, label: '\u2192 kitaru memory get sessions/topic_count \u2192 v2' },
        { row: 2, surface: 2, label: '\u2192 kitaru_memory_get("scratch/obsolete") \u2192 deleted' },
      ];

      let step = 0;
      let timers: number[] = [];
      let isVisible = false;

      function sched(fn: () => void, delay: number): number {
        const id = setTimeout(() => {
          const idx = timers.indexOf(id);
          if (idx !== -1) timers.splice(idx, 1);
          fn();
        }, delay);
        timers.push(id);
        return id;
      }

      function clearTimers() {
        timers.forEach(id => clearTimeout(id));
        timers = [];
      }

      function tick() {
        if (!isVisible) return;

        rows.forEach(r => r.classList.remove('highlight'));
        badges.forEach(b => b.classList.remove('active'));
        indicator?.classList.remove('visible');

        const { row, surface, label } = steps[step % steps.length];

        rows[row]?.classList.add('highlight');

        sched(() => {
          if (!isVisible) return;
          badges[surface]?.classList.add('active');
          if (indicator) {
            indicator.textContent = label;
            indicator.classList.add('visible');
          }
        }, 300);

        step++;
        sched(tick, 2200);
      }

      const observer = new IntersectionObserver((entries) => {
        const visible = entries[0].isIntersecting;
        if (visible && !isVisible) {
          isVisible = true;
          step = 0;
          sched(tick, 400);
        } else if (!visible && isVisible) {
          isVisible = false;
          clearTimers();
          rows.forEach(r => r.classList.remove('highlight'));
          badges.forEach(b => b.classList.remove('active'));
          indicator?.classList.remove('visible');
        }
      }, { threshold: 0.15 });

      observer.observe(shelf);

      window.addEventListener('pagehide', () => {
        observer.disconnect();
        clearTimers();
      }, { once: true });
    }
  }
</script>
