---
import { readingTime, AUTHORS, CATEGORY_STYLES } from '../../lib/blog';

interface Props {
  href: string;
  title: string;
  description: string;
  date: Date;
  author: string;
  category?: string;
  body?: string;
  image?: string;
}

const { href, title, description, date, author, category = 'Agents', body = '', image } = Astro.props;

const formatted = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
}).format(date);

const isoDate = date.toISOString();
const authorData = AUTHORS[author] ?? { initials: '??', color: '#9E9790' };
const catStyle = CATEGORY_STYLES[category] ?? CATEGORY_STYLES.Agents;
const readTime = readingTime(body);
---

<article class="blog-card" itemscope itemtype="https://schema.org/BlogPosting">
  <a href={href}>
    {image && (
      <div class="blog-card-image">
        <img src={image} alt={title} loading="lazy" />
      </div>
    )}
    <div class="blog-card-top">
      <span class="cat-pill" style={`background:${catStyle.bg};color:${catStyle.color};`}>{category}</span>
      <span class="blog-card-time">{readTime}</span>
    </div>
    <div class="blog-card-author">
      {authorData.image ? (
        <img class="avatar" src={authorData.image} alt={author} />
      ) : (
        <span class="avatar" style={`background:${authorData.color};`}>{authorData.initials}</span>
      )}
      <span class="blog-card-meta">
        <span itemprop="author">{author}</span> &middot; <time datetime={isoDate} itemprop="datePublished">{formatted}</time>
      </span>
    </div>
    <h3 class="blog-card-title" itemprop="headline">{title}</h3>
    <p class="blog-card-desc" itemprop="description">{description}</p>
  </a>
</article>

<style>
  .blog-card {
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: var(--color-surface-warm);
    overflow: hidden;
    transition: border-color 0.2s, transform 0.15s;
  }

  .blog-card:not(:has(.blog-card-image)) {
    padding: clamp(22px, 4vw, 28px);
    border-top: 3px solid var(--color-border);
    transition: border-color 0.2s, border-top-color 0.2s, transform 0.15s;
  }

  .blog-card:not(:has(.blog-card-image)):hover {
    border-top-color: var(--color-accent);
  }

  .blog-card:has(.blog-card-image) .blog-card-top,
  .blog-card:has(.blog-card-image) .blog-card-author,
  .blog-card:has(.blog-card-image) .blog-card-title,
  .blog-card:has(.blog-card-image) .blog-card-desc {
    padding-left: clamp(18px, 3vw, 24px);
    padding-right: clamp(18px, 3vw, 24px);
  }

  .blog-card:has(.blog-card-image) .blog-card-top {
    padding-top: clamp(16px, 3vw, 20px);
  }

  .blog-card:has(.blog-card-image) .blog-card-desc {
    padding-bottom: clamp(18px, 3vw, 24px);
  }

  .blog-card-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-bottom: 1px solid var(--color-border);
  }

  .blog-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .blog-card:hover {
    border-color: rgba(241, 120, 41, 0.3);
    transform: translateY(-2px);
  }

  .blog-card a {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .blog-card-top {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .cat-pill {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 4px;
    line-height: 1;
  }

  .blog-card-time {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .blog-card-author {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .avatar {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.52rem;
    font-weight: 600;
    color: #fff;
    flex-shrink: 0;
    object-fit: cover;
  }

  .blog-card-meta {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .blog-card-title {
    font-size: clamp(1.02rem, 2.5vw, 1.15rem);
    font-weight: 600;
    line-height: 1.35;
    color: var(--color-primary);
    margin: 0;
  }

  .blog-card-desc {
    font-size: clamp(0.8rem, 2vw, 0.86rem);
    line-height: 1.6;
    color: var(--color-secondary);
    margin: 0;
  }
</style>
