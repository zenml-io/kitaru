---
// Rich two-column CTA banner: dark background, "Get started with Kitaru" content
---

<div class="bottom-cta">
  <div class="bottom-cta-inner">
    <div class="bottom-cta-left">
      <h3 class="bottom-cta-heading">Start building durable agents</h3>
      <p class="bottom-cta-desc">
        Install Kitaru in seconds and make your AI workflows reliable, replayable, and observable.
      </p>
    </div>
    <div class="bottom-cta-right">
      <a href="/docs" class="bottom-cta-btn">
        Get Started
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </a>
    </div>
  </div>
</div>

<style>
  .bottom-cta {
    margin-top: 48px;
    margin-bottom: 16px;
  }

  .bottom-cta-inner {
    background: var(--color-primary);
    color: #fff;
    border-radius: 12px;
    padding: 36px 32px;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .bottom-cta-left {
    flex: 1;
    min-width: 0;
  }

  .bottom-cta-heading {
    font-size: clamp(1.15rem, 2.5vw, 1.35rem);
    font-weight: 700;
    margin: 0 0 8px;
    line-height: 1.2;
  }

  .bottom-cta-desc {
    font-size: 0.88rem;
    opacity: 0.8;
    line-height: 1.5;
    margin: 0;
  }

  .bottom-cta-right {
    flex-shrink: 0;
  }

  .bottom-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: 8px;
    font-family: var(--font-ui);
    font-size: 0.9rem;
    font-weight: 600;
    background: #fff;
    color: var(--color-primary);
    text-decoration: none;
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
  }

  .bottom-cta-btn:hover {
    background: #f5f5f5;
    transform: translateY(-1px);
  }

  .bottom-cta-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .bottom-cta-inner {
      flex-direction: column;
      text-align: center;
      gap: 20px;
      padding: 28px 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .bottom-cta-btn {
      transition: none;
    }
    .bottom-cta-btn:hover {
      transform: none;
    }
  }
</style>
