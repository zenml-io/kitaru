---
// Cta.astro — Bold CTA with primary dark background, ASCII canvas + mesh gradient
---

<section class="cta-section" id="cta">
  <canvas class="cta-ascii-canvas" aria-hidden="true"></canvas>
  <div class="cta-mesh" aria-hidden="true">
    <div class="cta-blob cta-blob-1"></div>
    <div class="cta-blob cta-blob-2"></div>
    <div class="cta-blob cta-blob-3"></div>
  </div>

  <div class="cta-inner" data-reveal>
    <h2 class="cta-headline">
      <span class="cta-line-problem">Your agent crashed at step 5.</span>
      <br>
      <span class="cta-line-solution">Stop re-running steps 1 through 4.</span>
    </h2>

    <div class="cta-actions">
      <div class="cta-install">
        <code>pip install kitaru</code>
        <button class="copy-btn" aria-label="Copy install command" data-copy="pip install kitaru">
          <svg class="copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
          <svg class="check-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
        </button>
      </div>
      <div class="cta-links">
        <a href="/docs" class="btn-accent">Read the docs</a>
        <a href="https://github.com/zenml-io/kitaru" target="_blank" rel="noopener" class="btn-secondary-dark">
          Star on GitHub
        </a>
      </div>
    </div>
    <p class="cta-note">Open source (Apache 2.0). pip install and go.</p>
  </div>
</section>

<style>
  .cta-section {
    padding: 140px 48px;
    text-align: center;
    position: relative;
    overflow: hidden;
    background: var(--color-primary);
  }

  .cta-ascii-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  /* ─── Mesh gradient ─── */
  .cta-mesh {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }

  .cta-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(90px);
    will-change: transform;
  }

  .cta-blob-1 {
    width: 700px;
    height: 700px;
    top: -30%;
    left: 0%;
    background: radial-gradient(circle, oklch(0.65 0.16 45 / 0.28) 0%, transparent 70%);
    animation: ctaMesh1 10s ease-in-out infinite alternate;
  }

  .cta-blob-2 {
    width: 650px;
    height: 650px;
    bottom: -35%;
    right: -5%;
    background: radial-gradient(circle, oklch(0.68 0.08 55 / 0.20) 0%, transparent 70%);
    animation: ctaMesh2 14s ease-in-out infinite alternate;
  }

  .cta-blob-3 {
    width: 550px;
    height: 550px;
    top: 10%;
    right: 20%;
    background: radial-gradient(circle, oklch(0.65 0.16 45 / 0.18) 0%, transparent 70%);
    animation: ctaMesh3 8s ease-in-out infinite alternate;
  }

  @keyframes ctaMesh1 {
    0%   { transform: translate(0, 0) scale(1); }
    25%  { transform: translate(25%, 18%) scale(1.25); }
    50%  { transform: translate(-10%, 30%) scale(0.85); }
    75%  { transform: translate(18%, -12%) scale(1.2); }
    100% { transform: translate(-8%, 15%) scale(1.05); }
  }

  @keyframes ctaMesh2 {
    0%   { transform: translate(0, 0) scale(1); }
    25%  { transform: translate(-20%, -15%) scale(1.18); }
    50%  { transform: translate(15%, -25%) scale(0.82); }
    75%  { transform: translate(-12%, 10%) scale(1.12); }
    100% { transform: translate(10%, -8%) scale(0.95); }
  }

  @keyframes ctaMesh3 {
    0%   { transform: translate(0, 0) scale(1); }
    33%  { transform: translate(-30%, 22%) scale(1.3); }
    66%  { transform: translate(22%, -18%) scale(0.8); }
    100% { transform: translate(-12%, 8%) scale(1.15); }
  }

  /* Radial vignette — darkens center so text/input pops */
  .cta-section::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    background: radial-gradient(ellipse 70% 80% at 50% 50%, var(--color-primary) 0%, transparent 100%);
    pointer-events: none;
  }

  .cta-inner {
    position: relative;
    z-index: 10;
    max-width: 900px;
    margin: 0 auto;
  }

  .cta-headline {
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin: 0;
  }

  .cta-line-problem {
    font-weight: 400;
    color: oklch(1 0 0 / 0.5);
  }

  .cta-line-solution {
    font-weight: 700;
    color: var(--color-dark-text);
  }

  .cta-actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    margin-top: 48px;
  }

  .cta-install {
    display: inline-flex;
    align-items: center;
    gap: 0;
    background: oklch(1 0 0 / 0.06);
    border: 1px solid oklch(1 0 0 / 0.15);
    border-radius: 8px;
    padding: 4px 4px 4px 20px;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .cta-install:hover {
    border-color: oklch(0.65 0.16 45 / 0.4);
    box-shadow: 0 0 0 3px oklch(0.65 0.16 45 / 0.08);
  }

  .cta-install code {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-dark-text);
    user-select: all;
  }

  .cta-install .copy-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    color: oklch(1 0 0 / 0.35);
    border-radius: 6px;
    cursor: pointer;
    transition: color 0.2s, background 0.2s;
    margin-left: 8px;
    flex-shrink: 0;
  }

  .cta-install .copy-btn:hover {
    color: oklch(1 0 0 / 0.7);
    background: oklch(1 0 0 / 0.06);
  }

  .cta-install .copy-btn .check-icon {
    display: none;
    color: var(--color-success);
  }

  .cta-install .copy-btn.copied .copy-icon {
    display: none;
  }

  .cta-install .copy-btn.copied .check-icon {
    display: block;
    animation: cta-check-pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes cta-check-pop {
    0% { transform: scale(0); opacity: 0; }
    60% { transform: scale(1.2); }
    100% { transform: scale(1); opacity: 1; }
  }

  .cta-links {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-secondary-dark {
    font-family: var(--font-ui);
    font-size: 15px;
    font-weight: 500;
    color: oklch(1 0 0 / 0.7);
    background: transparent;
    padding: 14px 28px;
    border-radius: 8px;
    border: 1px solid oklch(1 0 0 / 0.15);
    cursor: pointer;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }

  .btn-secondary-dark:hover {
    border-color: oklch(1 0 0 / 0.3);
    color: oklch(1 0 0 / 0.9);
  }

  .cta-note {
    font-size: 0.75rem;
    margin-top: 14px;
    color: oklch(1 0 0 / 0.35);
    text-align: center;
  }

  @media (max-width: 768px) {
    .cta-section {
      padding: 80px 20px;
    }

    .cta-ascii-canvas {
      display: none;
    }

    .cta-blob-1 { width: 250px; height: 250px; }
    .cta-blob-2 { width: 200px; height: 200px; }
    .cta-blob-3 { width: 180px; height: 180px; }

    .cta-links {
      flex-direction: column;
      width: 100%;
      max-width: 320px;
    }

    .cta-links .btn-accent,
    .cta-links .btn-secondary-dark {
      width: 100%;
      justify-content: center;
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .cta-headline {
      font-size: clamp(1.6rem, 5vw, 2rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-ascii-canvas {
      display: none;
    }

    .cta-blob {
      animation: none;
    }
  }
</style>

<script>
  // ─── CTA ASCII Canvas Background ───
  import { sizeCanvasToParent, attachMouseTracker, attachResizeHandler, getAttractorPositions } from '../scripts/canvas-utils';

  const ctaCanvas = document.querySelector<HTMLCanvasElement>('.cta-ascii-canvas');
  if (ctaCanvas) {
    const ctaCtx = ctaCanvas.getContext('2d');
    if (ctaCtx) {
      const CHARS = '|-+><{}/.:\\01';
      const GRID = 28;
      const RADIUS = 220;
      const ATTRACT_R = 260;
      const FSIZE = 14;
      const DPR = Math.min(window.devicePixelRatio || 1, 2);
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      interface Cell {
        x: number;
        y: number;
        char: string;
        phase: number;
        base: number;
      }

      let grid: Cell[] = [];
      let mx = -9999;
      let my = -9999;
      let active = false;
      let raf = 0;
      let isCtaVisible = true;
      let cW = 0;
      let cH = 0;

      function build() {
        grid = [];
        cW = ctaCanvas!.width / DPR;
        cH = ctaCanvas!.height / DPR;
        const cols = Math.ceil(cW / GRID) + 1;
        const rows = Math.ceil(cH / GRID) + 1;

        for (let r = 0; r < rows; r++) {
          for (let c = 0; c < cols; c++) {
            grid.push({
              x: c * GRID,
              y: r * GRID,
              char: CHARS[Math.floor(Math.random() * CHARS.length)],
              phase: Math.random() * Math.PI * 2,
              base: 0.10 + Math.random() * 0.16,
            });
          }
        }
      }

      function sizeCanvas() {
        const dims = sizeCanvasToParent(ctaCanvas!, ctaCtx!, DPR);
        cW = dims.w;
        cH = dims.h;
        build();
      }

      function drawOnce() {
        ctaCtx!.clearRect(0, 0, cW, cH);
        ctaCtx!.font = `${FSIZE}px var(--font-mono), 'JetBrains Mono', monospace`;
        ctaCtx!.textAlign = 'center';
        ctaCtx!.textBaseline = 'middle';

        for (const cell of grid) {
          ctaCtx!.globalAlpha = 0.06;
          ctaCtx!.fillStyle = 'rgb(241,120,41)';
          ctaCtx!.fillText(cell.char, cell.x, cell.y);
        }
        ctaCtx!.globalAlpha = 1;
      }

      function loop(time: number) {
        if (document.hidden) {
          raf = requestAnimationFrame(loop);
          return;
        }

        ctaCtx!.clearRect(0, 0, cW, cH);
        ctaCtx!.font = `${FSIZE}px var(--font-mono), 'JetBrains Mono', monospace`;
        ctaCtx!.textAlign = 'center';
        ctaCtx!.textBaseline = 'middle';
        ctaCtx!.fillStyle = 'rgb(241,120,41)';

        const t = time * 0.001;

        // Two wandering attractors — always running
        const { at1X, at1Y, at2X, at2Y } = getAttractorPositions(t, cW, cH);

        for (const cell of grid) {
          let opacity = cell.base;
          let dx = 0;
          let dy = 0;
          let scale = 1;

          // Ambient breathing — punchy
          const breath = Math.sin(t * 0.8 + cell.phase) * 0.05;
          opacity = cell.base + breath;
          opacity = Math.max(0.05, Math.min(opacity, 0.28));

          // Attractor 1 — ALWAYS active (primary)
          {
            const adx = cell.x - at1X;
            const ady = cell.y - at1Y;
            const adist = Math.sqrt(adx * adx + ady * ady);
            if (adist < ATTRACT_R) {
              const ratio = 1 - (adist / ATTRACT_R);
              const ease = ratio * ratio;
              opacity = opacity + (0.38 - opacity) * ease;
              if (adist > 0.1) {
                dx += (adx / adist) * ease * 6;
                dy += (ady / adist) * ease * 6;
              }
              scale = Math.max(scale, 1 + ease * 0.18);
            }
          }

          // Attractor 2 — ALWAYS active (secondary, gentler)
          {
            const adx = cell.x - at2X;
            const ady = cell.y - at2Y;
            const adist = Math.sqrt(adx * adx + ady * ady);
            if (adist < ATTRACT_R * 0.8) {
              const ratio = 1 - (adist / (ATTRACT_R * 0.8));
              const ease = ratio * ratio;
              opacity = opacity + (0.32 - opacity) * ease * 0.6;
              if (adist > 0.1) {
                dx += (adx / adist) * ease * 4;
                dy += (ady / adist) * ease * 4;
              }
              scale = Math.max(scale, 1 + ease * 0.12);
            }
          }

          // Cursor interaction — stacks on top
          if (active) {
            const cdx = cell.x - mx;
            const cdy = cell.y - my;
            const cdist = Math.sqrt(cdx * cdx + cdy * cdy);

            if (cdist < RADIUS) {
              const ratio = 1 - (cdist / RADIUS);
              const ease = ratio * ratio;
              opacity = opacity + (0.55 - opacity) * ease;
              if (cdist > 0.1) {
                dx += (cdx / cdist) * ease * 8;
                dy += (cdy / cdist) * ease * 8;
              }
              scale = Math.max(scale, 1 + ease * 0.3);
            }
          }

          ctaCtx!.globalAlpha = Math.min(opacity, 0.60);
          ctaCtx!.save();
          ctaCtx!.translate(cell.x + dx, cell.y + dy);
          if (scale !== 1) ctaCtx!.scale(scale, scale);
          ctaCtx!.fillText(cell.char, 0, 0);
          ctaCtx!.restore();
        }

        ctaCtx!.globalAlpha = 1;
        raf = isCtaVisible ? requestAnimationFrame(loop) : 0;
      }

      // Mouse/touch tracking
      attachMouseTracker(
        ctaCanvas.closest('section')!,
        ctaCanvas,
        (x, y) => { mx = x; my = y; active = true; },
        () => { active = false; }
      );

      // Init
      sizeCanvas();

      const ctaObs = new IntersectionObserver((entries) => {
        isCtaVisible = entries[0].isIntersecting;
        if (isCtaVisible && !reducedMotion && raf === 0) raf = requestAnimationFrame(loop);
        else if (!isCtaVisible) { cancelAnimationFrame(raf); raf = 0; }
      }, { threshold: 0 });
      ctaObs.observe(ctaCanvas!.closest('section')!);

      if (reducedMotion) {
        drawOnce();
      } else {
        raf = requestAnimationFrame(loop);
      }

      attachResizeHandler(() => {
        sizeCanvas();
        if (reducedMotion) drawOnce();
      });
    }
  }

  // Copy-to-clipboard for CTA install command
  document.querySelectorAll<HTMLButtonElement>('.cta-install .copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = btn.dataset.copy ?? '';
      navigator.clipboard.writeText(text).then(() => {
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 1500);
      }).catch(() => {});
    });
  });
</script>
