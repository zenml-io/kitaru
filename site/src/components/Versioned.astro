---
// Versioned.astro — "Every artifact. Every config. Every execution. Versioned." (ZenML DNA)
---

<section class="versioned-section" style="padding: 80px clamp(24px, 5vw, 80px) 100px;">
  <div class="section-inner">
    <span class="section-eyebrow" data-reveal>Built on ZenML's DNA</span>
    <h2 class="section-title" data-reveal data-reveal-delay="1">Every artifact. Every config.<br>Every execution. Versioned.</h2>
    <p class="section-desc" data-reveal data-reveal-delay="2">Four years of ML infrastructure taught us: version everything. Kitaru tracks every output, every setting, every run.</p>

    <div class="versioned-grid" id="versionedGrid">

      <!-- Artifacts -->
      <div class="v-card">
        <div class="v-card-header">Artifacts</div>
        <div class="v-code-block">
          <pre class="v-pre"><code><span class="cmt"># Checkpoint outputs auto-persisted</span>
<span class="dec">@kitaru.checkpoint</span>
<span class="kw">def</span> <span class="fn">analyze</span>(code: <span class="var">str</span>) <span class="op">-></span> <span class="var">str</span>:
    <span class="kw">return</span> call_llm(code)  <span class="cmt"># versioned</span>

<span class="cmt"># Load across executions</span>
prev <span class="op">=</span> kitaru.<span class="fn">load</span>(
    exec_id<span class="op">=</span><span class="str">"kr-a8f3c2"</span>, name<span class="op">=</span><span class="str">"analyze"</span>
)</code></pre>
        </div>
        <p class="v-desc">Every checkpoint output is automatically persisted and versioned. Load any previous result by name and version.</p>
      </div>

      <!-- Configs -->
      <div class="v-card">
        <div class="v-card-header">Configs</div>
        <div class="v-code-block">
          <pre class="v-pre"><code><span class="cmt"># Named environments</span>
kitaru.<span class="fn">configure</span>(
    name<span class="op">=</span><span class="str">"prod"</span>,
    server<span class="op">=</span><span class="str">"https://kitaru.co"</span>,
    store<span class="op">=</span><span class="str">"s3://bucket/prod"</span>,
    compute<span class="op">=</span><span class="str">"kubernetes"</span>,
)

<span class="cmt"># Use by name</span>
<span class="dec">@kitaru.flow</span>(config<span class="op">=</span><span class="str">'prod'</span>)
<span class="kw">def</span> <span class="fn">my_agent</span>(): ...</code></pre>
        </div>
        <p class="v-desc">Named dev/staging/prod configs with automatic versioning. Model routing profiles included.</p>
      </div>

      <!-- Lineage -->
      <div class="v-card">
        <div class="v-card-header">Lineage</div>
        <div class="v-code-block">
          <pre class="v-pre"><code><span class="cmt"># Every execution records:</span>
<span class="cmt"># - which config version was active</span>
<span class="cmt"># - which artifacts were produced</span>
<span class="cmt"># - who provided human input</span>
<span class="cmt"># - full dependency graph</span>

<span class="cmt"># Query any execution</span>
client <span class="op">=</span> KitaruClient()
ex <span class="op">=</span> client.executions.<span class="fn">get</span>(<span class="str">"kr-a8f3c2"</span>)
ex.checkpoints  <span class="cmt"># timeline</span>
ex.artifacts    <span class="cmt"># all outputs</span></code></pre>
        </div>
        <p class="v-desc">Every execution records what config, what artifacts, who provided input. Full reproducibility.</p>
      </div>

    </div>
  </div>
</section>

<style>
  .versioned-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 48px;
  }

  .v-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s ease, border-color 0.3s;
  }

  .versioned-grid.visible .v-card:nth-child(1) { transition-delay: 0s; }
  .versioned-grid.visible .v-card:nth-child(2) { transition-delay: 0.12s; }
  .versioned-grid.visible .v-card:nth-child(3) { transition-delay: 0.24s; }

  .versioned-grid.visible .v-card {
    opacity: 1;
    transform: translateY(0);
  }

  .v-card:hover {
    border-color: var(--color-muted);
  }

  .v-card-header {
    padding: 16px 20px 12px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    font-weight: 600;
  }

  .v-code-block {
    background: #1A1714;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .v-pre {
    margin: 0;
    padding: 16px 20px;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    line-height: 1.7;
    color: #E8E4DE;
    overflow-x: auto;
    background: transparent;
  }

  .v-pre code { font-family: inherit; }
  .v-pre .kw { color: #C792EA; }
  .v-pre .fn { color: #82AAFF; }
  .v-pre .str { color: #C3E88D; }
  .v-pre .var { color: #F78C6C; }
  .v-pre .op { color: #89DDFF; }
  .v-pre .num { color: #F78C6C; }
  .v-pre .dec { color: #FFCB6B; }
  .v-pre .cmt { color: #546E7A; font-style: italic; }

  .v-desc {
    padding: 14px 20px 18px;
    font-size: 0.8rem;
    color: var(--color-secondary);
    line-height: 1.55;
    font-weight: 300;
  }

  @media (max-width: 900px) {
    .versioned-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const vGridObs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        vGridObs.disconnect();
      }
    });
  }, { threshold: 0.15 });

  const vGrid = document.getElementById('versionedGrid');
  if (vGrid) vGridObs.observe(vGrid);
</script>
