---
// ProblemStatement.astro — "Why now" narrative between Hero and code showcase
---

<section class="section-pad problem-section">
  <div class="section-inner">
    <span class="section-eyebrow" data-reveal>THE PROBLEM</span>
    <h2 class="section-title problem-headline" data-reveal data-reveal-delay="1">
      Your agents work. But they're trapped.
    </h2>

    <div class="problem-grid">

      <div class="why-card" data-reveal="scale-up" data-reveal-delay="2">
        <div class="card-glow"></div>
        <div class="why-card-image">
          <img src="https://assets.kitaru.ai/content/site/ffb15262/k-prob-1.avif" alt="Agents die when your laptop sleeps" loading="eager" onerror="this.style.display='none'" />
        </div>
        <div class="why-card-content">
          <h3>They die when your laptop sleeps</h3>
          <p>One crash, one timeout, one closed lid — and hours of LLM calls vanish. You start over from scratch.</p>
        </div>
      </div>

      <div class="why-card" data-reveal="scale-up" data-reveal-delay="3">
        <div class="card-glow"></div>
        <div class="why-card-image">
          <img src="https://assets.kitaru.ai/content/site/733ddc89/k-prob-2.avif" alt="Agents can't coordinate" loading="eager" onerror="this.style.display='none'" />
        </div>
        <div class="why-card-content">
          <h3>They can't coordinate with other agents</h3>
          <p>No pause, no resume, no human-in-the-loop. Every agent is a fire-and-forget black box.</p>
        </div>
      </div>

      <div class="why-card" data-reveal="scale-up" data-reveal-delay="4">
        <div class="card-glow"></div>
        <div class="why-card-image">
          <img src="https://assets.kitaru.ai/content/site/34944ab3/k-prob-3.avif" alt="Results vanish when agents crash" loading="eager" onerror="this.style.display='none'" />
        </div>
        <div class="why-card-content">
          <h3>Their intermediate results vanish when they crash</h3>
          <p>No checkpoints, no artifacts, no audit trail. When something goes wrong you have nothing to debug.</p>
        </div>
      </div>

    </div>

    <p class="problem-conclusion" data-reveal data-reveal-delay="5">
      Kitaru moves your agents from your machine to your infrastructure.
    </p>
  </div>
</section>

<style>
  .problem-section {
    background: var(--color-bg);
  }

  .problem-headline {
    max-width: 700px;
  }

  .problem-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 48px;
  }

  .problem-conclusion {
    margin-top: 40px;
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    font-weight: 500;
    color: var(--color-primary);
    letter-spacing: -0.01em;
  }

  /* ── Card styles — identical to WhyKitaru ── */
  .why-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s;
  }

  .why-card:hover {
    border-color: var(--color-muted);
  }

  .card-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at var(--mouse-x, 50%) var(--mouse-y, 50%), oklch(0.65 0.16 45 / 0.04), transparent 60%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
    z-index: 1;
  }

  .why-card:hover .card-glow {
    opacity: 1;
  }

  .why-card-image {
    width: 100%;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface-warm, oklch(0.97 0.005 70));
    min-height: 120px;
  }

  .why-card-placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--color-surface-warm, oklch(0.97 0.005 70));
  }

  .why-card-image img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .why-card-content {
    position: relative;
    z-index: 2;
    padding: 24px 28px 28px;
  }

  .why-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .why-card p {
    color: var(--color-secondary);
    font-size: 0.85rem;
    line-height: 1.6;
    font-weight: 300;
  }

  @media (max-width: 768px) {
    .problem-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.querySelectorAll('.problem-section .why-card').forEach(card => {
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = (card as HTMLElement).getBoundingClientRect();
      (card as HTMLElement).style.setProperty('--mouse-x', ((e.clientX - rect.left) / rect.width * 100) + '%');
      (card as HTMLElement).style.setProperty('--mouse-y', ((e.clientY - rect.top) / rect.height * 100) + '%');
    });
    card.addEventListener('mouseleave', () => {
      (card as HTMLElement).style.setProperty('--mouse-x', '50%');
      (card as HTMLElement).style.setProperty('--mouse-y', '50%');
    });
  });
</script>
