---
// Architecture.astro — Two-column: layer stack + code snippet on dark background
---

<section class="arch-section section-pad dark-section" aria-labelledby="arch-heading">
  <div class="section-inner">
    <!-- Eyebrow + title above the grid -->
    <div class="arch-header" data-reveal>
      <span class="section-eyebrow">Architecture</span>
      <h2 id="arch-heading" class="section-title arch-title">
        Orchestration layer.<br><em class="arch-italic">Not a framework.</em>
      </h2>
    </div>

    <div class="arch-grid">

      <!-- Left column: layer stack -->
      <div class="arch-left" data-reveal="fade-left">
        <div class="arch-stack">
          <div class="arch-layer arch-layer-agent">
            <div class="arch-layer-label">Your Agent Code</div>
            <div class="arch-layer-pills">
              <span class="arch-pill">PydanticAI</span>
              <span class="arch-pill">OpenAI SDK</span>
              <span class="arch-pill">CrewAI</span>
              <span class="arch-pill">Raw Python</span>
            </div>
            <div class="arch-layer-note">Write agents your way</div>
          </div>

          <div class="arch-layer arch-layer-sdk">
            <div class="arch-layer-label">Kitaru SDK</div>
            <div class="arch-layer-pills">
              <span class="arch-pill">@flow</span>
              <span class="arch-pill">@checkpoint</span>
              <span class="arch-pill">wait()</span>
              <span class="arch-pill">llm()</span>
              <span class="arch-pill">log()</span>
              <span class="arch-pill">save()</span>
              <span class="arch-pill">load()</span>
              <span class="arch-pill">memory()</span>
              <span class="arch-pill">configure()</span>
            </div>
            <div class="arch-layer-note">Core primitives. Full durability.</div>
          </div>

          <div class="arch-layer arch-layer-engine">
            <div class="arch-layer-label">Kitaru Engine</div>
            <div class="arch-layer-pills">
              <span class="arch-pill">Checkpointer</span>
              <span class="arch-pill">DAG Builder</span>
              <span class="arch-pill">Replay</span>
              <span class="arch-pill">Cost Engine</span>
            </div>
            <div class="arch-layer-note">Powered by ZenML</div>
          </div>

          <div class="arch-layer arch-layer-infra">
            <div class="arch-layer-label">Infrastructure</div>
            <div class="arch-layer-pills">
              <span class="arch-pill">Kubernetes</span>
              <span class="arch-pill">AWS / GCP / Azure</span>
              <span class="arch-pill">S3 / GCS</span>
              <span class="arch-pill">SQL Database</span>
            </div>
            <div class="arch-layer-note">Your cloud</div>
          </div>
        </div>
      </div>

      <!-- Right column: code window -->
      <div class="arch-right" data-reveal="fade-right">
        <div class="arch-code-window">
          <div class="arch-code-header">
            <div class="arch-code-dots">
              <span class="code-dot"></span>
              <span class="code-dot"></span>
              <span class="code-dot"></span>
            </div>
            <span class="arch-code-filename">agent.py</span>
          </div>
          <pre class="arch-code-pre code-syntax" aria-label="Example Kitaru agent code"><code><span class="kw">import</span> kitaru
<span class="kw">from</span> kitaru <span class="kw">import</span> flow, checkpoint

<span class="dec">@flow</span>
<span class="kw">def</span> <span class="fn">coding_agent</span>(issue: <span class="var">str</span>) <span class="op">-></span> <span class="var">str</span>:
    plan <span class="op">=</span> <span class="fn">analyze_issue</span>(issue)
    patch <span class="op">=</span> <span class="fn">write_code</span>(plan)

    <span class="cmt"># Pauses. Resumes when input arrives.</span>
    approved <span class="op">=</span> kitaru.<span class="fn">wait</span>(
        <span class="var">bool</span>, question<span class="op">=</span><span class="str">"Merge this PR?"</span>
    )
    <span class="kw">if</span> approved:
        <span class="fn">merge</span>(patch)
    <span class="kw">return</span> patch</code></pre>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Title colors for dark background */
  .arch-title {
    color: var(--color-dark-text);
  }

  .arch-italic {
    font-style: italic;
    font-weight: 300;
    color: oklch(1 0 0 / 0.45);
  }

  /* Two-column grid */
  .arch-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: stretch;
  }

  .arch-header {
    margin-bottom: 40px;
  }

  /* Layer stack */
  .arch-stack {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .arch-layer {
    display: grid;
    grid-template-columns: 130px 1fr auto;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    border-radius: 8px;
    border: 1px solid transparent;
  }

  .arch-layer-agent {
    background: oklch(0.73 0.12 80 / 0.12);
    border-color: oklch(0.73 0.12 80 / 0.3);
  }

  .arch-layer-sdk {
    background: oklch(0.65 0.16 45 / 0.12);
    border-color: oklch(0.65 0.16 45 / 0.3);
  }

  .arch-layer-engine {
    background: oklch(0.68 0.08 55 / 0.12);
    border-color: oklch(0.68 0.08 55 / 0.3);
  }

  .arch-layer-infra {
    background: oklch(1 0 0 / 0.04);
    border-color: oklch(1 0 0 / 0.1);
  }

  .arch-layer-label {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
  }

  .arch-layer-agent .arch-layer-label { color: oklch(0.73 0.12 80 / 0.95); }
  .arch-layer-sdk .arch-layer-label { color: oklch(0.65 0.16 45 / 0.95); }
  .arch-layer-engine .arch-layer-label { color: oklch(0.68 0.08 55 / 0.95); }
  .arch-layer-infra .arch-layer-label { color: oklch(1 0 0 / 0.6); }

  .arch-layer-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .arch-pill {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    padding: 3px 10px;
    border-radius: 4px;
  }

  .arch-layer-agent .arch-pill {
    color: oklch(0.73 0.12 80 / 0.95);
    background: oklch(0.73 0.12 80 / 0.14);
    border: 1px solid oklch(0.73 0.12 80 / 0.3);
  }

  .arch-layer-sdk .arch-pill {
    color: oklch(0.65 0.16 45 / 0.95);
    background: oklch(0.65 0.16 45 / 0.14);
    border: 1px solid oklch(0.65 0.16 45 / 0.3);
  }

  .arch-layer-engine .arch-pill {
    color: oklch(0.68 0.08 55 / 0.95);
    background: oklch(0.68 0.08 55 / 0.14);
    border: 1px solid oklch(0.68 0.08 55 / 0.3);
  }

  .arch-layer-infra .arch-pill {
    color: oklch(1 0 0 / 0.5);
    background: oklch(1 0 0 / 0.06);
    border: 1px solid oklch(1 0 0 / 0.1);
  }

  .arch-layer-note {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-style: italic;
    color: oklch(1 0 0 / 0.4);
    white-space: nowrap;
    text-align: right;
  }

  .arch-left {
    display: flex;
    flex-direction: column;
  }

  .arch-stack {
    flex: 1;
  }

  .arch-right {
    display: flex;
    flex-direction: column;
  }

  /* Code window (dark variant) */
  .arch-code-window {
    background: oklch(0.16 0.015 60);
    border: 1px solid oklch(1 0 0 / 0.08);
    border-radius: 12px;
    overflow: hidden;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .arch-code-pre {
    flex: 1;
  }

  .arch-code-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-bottom: 1px solid oklch(1 0 0 / 0.06);
  }

  .arch-code-dots {
    display: flex;
    gap: 6px;
  }

  .arch-code-filename {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: oklch(1 0 0 / 0.35);
  }

  .arch-code-pre {
    padding: 20px;
    margin: 0;
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.7;
    color: var(--color-dark-text);
    -webkit-overflow-scrolling: touch;
  }

  /* Responsive: single column below 768px */
  @media (max-width: 768px) {
    .arch-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .arch-layer {
      grid-template-columns: 1fr;
      gap: 8px;
    }

    .arch-layer-note {
      text-align: left;
      white-space: normal;
    }

    .arch-layer-label {
      white-space: normal;
    }

    .arch-code-window {
      margin-top: 0;
      position: relative;
    }

    .arch-code-window::after {
      content: '';
      position: absolute;
      top: 0;
      right: 0;
      bottom: 0;
      width: 32px;
      background: linear-gradient(90deg, transparent, oklch(0.16 0.015 60));
      pointer-events: none;
      border-radius: 0 12px 12px 0;
    }
  }

  @media (max-width: 480px) {
    .arch-layer {
      padding: 12px 14px;
    }

    .arch-code-pre {
      padding: 16px;
      font-size: 0.72rem;
    }
  }
</style>
