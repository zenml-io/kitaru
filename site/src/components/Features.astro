---
// Features.astro — Full-width scroll-stacking cards with text left / animation right
---

<section id="how-it-works" class="features-section">
  <!-- Header scrolls away normally -->
  <div class="features-header">
    <div class="section-inner">
      <span class="section-eyebrow" data-reveal>How it works</span>
      <h2 class="section-title" data-reveal data-reveal-delay="1">Four things. Not forty.</h2>
      <p class="section-desc" data-reveal data-reveal-delay="2">Everything your agents need to ship. Nothing extra to learn.</p>
    </div>
  </div>

  <!-- Sticky container — outside section-inner to avoid overflow:clip breaking sticky -->
  <div class="features-sticky-container">

    <!-- Card 1: Pause & Resume -->
    <div class="feature-card" data-feature="0">
      <div class="card-glow"></div>
      <div class="feature-card-inner">
        <div class="feature-text">
          <div class="feature-number">01 — Pause & Resume</div>
          <h3>Pause. Get input. Continue.</h3>
          <p>Suspends at decision points, releases compute, and picks up when input arrives — from a human, another agent, or a webhook. Hours or days later.</p>
        </div>
        <div class="feature-visual">
          <div class="anim-pause-resume" id="animPause">
            <div class="timeline-track"></div>
            <div class="progress-fill" id="progressFill"></div>
            <div class="pr-step" style="left:15%" data-idx="0">1</div>
            <div class="pr-step" style="left:30%" data-idx="1">2</div>
            <div class="pr-step" style="left:45%" data-idx="2">3</div>
            <div class="pr-step" style="left:60%" data-idx="3">4</div>
            <div class="pr-step" style="left:75%" data-idx="4">5</div>
            <div class="pr-step" style="left:90%" data-idx="5">6</div>
            <div class="human-badge" id="humanBadge">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M6 1v10M1 6h10" stroke="var(--color-accent-warm)" stroke-width="1.2" stroke-linecap="round"/></svg>
              Waiting for input...
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Card 2: Replay from Failure -->
    <div class="feature-card" data-feature="1">
      <div class="card-glow"></div>
      <div class="feature-card-inner">
        <div class="feature-text">
          <div class="feature-number">02 — Replay from Failure</div>
          <h3>Crash at step 7? Resume from step 7.</h3>
          <p>Every step is checkpointed. Fix the issue and pick up where you left off — no re-burning tokens.</p>
        </div>
        <div class="feature-visual">
          <div class="anim-replay" id="animReplay">
            <div class="replay-row">
              <div class="rstep" data-idx="0">1</div>
              <div class="rstep" data-idx="1">2</div>
              <div class="rstep" data-idx="2">3</div>
              <div class="rstep" data-idx="3">4</div>
              <div class="rstep" data-idx="4">5</div>
              <div class="rstep" data-idx="5">6</div>
              <div class="rstep" data-idx="6">7</div>
            </div>
            <div class="replay-status" id="replayStatus">Running agent...</div>
            <div class="cost-saved" id="costSaved">$12.40 in tokens saved</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Card 3: Bring Your Framework -->
    <div class="feature-card" data-feature="2">
      <div class="card-glow"></div>
      <div class="feature-card-inner">
        <div class="feature-text">
          <div class="feature-number">03 — Bring Your Framework</div>
          <h3>PydanticAI. CrewAI. Whatever.</h3>
          <p>Wrap it with Kitaru and it becomes durable. No lock-in. No opinions. Your framework, our infrastructure.</p>
        </div>
        <div class="feature-visual">
          <div class="anim-framework" id="animFramework">
            <div class="framework-orbit"></div>
            <div class="kitaru-core">kitaru</div>
            <div class="fw-item" style="top: 12%; left: 50%; transform: translateX(-50%);">PydanticAI</div>
            <div class="fw-item" style="top: 50%; right: 5%; transform: translateY(-50%);">OpenAI SDK</div>
            <div class="fw-item" style="bottom: 12%; left: 50%; transform: translateX(-50%);">Your code</div>
            <div class="fw-item" style="top: 50%; left: 5%; transform: translateY(-50%);">CrewAI</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Card 4: Parallel Branches -->
    <div class="feature-card feature-card--last" data-feature="3">
      <div class="card-glow"></div>
      <div class="feature-card-inner">
        <div class="feature-text">
          <div class="feature-number">04 — Parallel Branches</div>
          <h3>Fan out. Each branch checkpoints independently.</h3>
          <p><code style="font-family:var(--font-mono);font-size:0.82em;color:var(--color-accent);">checkpoint.submit()</code> dispatches branches concurrently. Each has its own checkpoint history. Replay just the failed branch.</p>
        </div>
        <div class="feature-visual">
          <div class="anim-parallel" id="animParallel">
            <div class="par-source"></div>
            <div class="par-branch" data-idx="0">
              <div class="par-line"></div>
              <div class="par-dot" data-dot="0"></div>
              <div class="par-dot" data-dot="1"></div>
              <div class="par-dot" data-dot="2"></div>
            </div>
            <div class="par-branch" data-idx="1">
              <div class="par-line"></div>
              <div class="par-dot" data-dot="0"></div>
              <div class="par-dot" data-dot="1"></div>
              <div class="par-dot" data-dot="2"></div>
            </div>
            <div class="par-branch" data-idx="2">
              <div class="par-line"></div>
              <div class="par-dot" data-dot="0"></div>
              <div class="par-dot" data-dot="1"></div>
              <div class="par-dot" data-dot="2"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Content-box spacer: sticky constraint ignores padding & margin,
         only real content extends the rectangle. This div is the runway. -->
    <div class="sticky-runway" aria-hidden="true"></div>
  </div>
</section>

<style>
  /* ═══ Section container ═══ */
  .features-section {
    /* No overflow restrictions — sticky needs open overflow */
    background: url('https://assets.kitaru.ai/content/site/01af00b0/kit-bg.avif') center bottom / cover no-repeat;
    background-attachment: fixed;
  }

  .features-header {
    padding: 80px clamp(24px, 5vw, 80px) 48px;
  }

  /* Override global .section-inner overflow:clip — it prevents the
     IntersectionObserver from detecting the section-desc (which starts
     shifted 32px down via data-reveal transform). */
  .features-header .section-inner {
    overflow: visible;
  }

  /* ═══ Sticky stacking container ═══ */
  .features-sticky-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(24px, 5vw, 80px);
  }

  /* ═══ Sticky cards ═══ */
  .feature-card {
    position: sticky;
    top: 25vh;
    background: var(--color-bg);
    border-radius: 16px;
    border: 1px solid var(--color-border);
    box-shadow: 0 -4px 20px rgba(26,23,20,0.04);
    margin-bottom: 40vh;
    overflow: hidden;
  }

  .feature-card--last {
    margin-bottom: 40vh;
  }

  /* 8px reveal cadence so each prior card's top edge remains visible. */
  .feature-card[data-feature="1"] { top: calc(25vh + 8px); }
  .feature-card[data-feature="2"] { top: calc(25vh + 16px); }
  .feature-card[data-feature="3"] { top: calc(25vh + 24px); }

  /* Content fades out when card is no longer active */
  .feature-card-inner {
    transition: opacity 0.4s ease;
  }
  .feature-card.faded .feature-card-inner {
    opacity: 0.15;
  }

  /* Card hover glow — follows cursor */
  .card-glow {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: radial-gradient(circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(241,120,41,0.04), transparent 60%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
    z-index: 1;
  }

  .feature-card:hover .card-glow {
    opacity: 1;
  }

  /* ═══ Card inner grid — text left, visual flush right ═══ */
  .feature-card-inner {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 0;
    align-items: stretch;
    min-height: 60vh;
  }

  /* ═══ Text area ═══ */
  .feature-text {
    position: relative;
    z-index: 2;
    padding: 48px clamp(32px, 3vw, 56px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .feature-number {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    color: var(--color-muted);
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .feature-card h3 {
    font-size: clamp(1.3rem, 2.5vw, 1.75rem);
    font-weight: 700;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .feature-card p {
    color: var(--color-secondary);
    font-size: clamp(0.9rem, 1.2vw, 1.05rem);
    line-height: 1.7;
    font-weight: 300;
    max-width: 380px;
  }

  /* ═══ Visual area — full height, flush right, border-left separator ═══ */
  .feature-visual {
    background: var(--color-surface-warm);
    border-left: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Round only the right corners to match card border-radius */
    border-radius: 0 15px 15px 0;
  }

  /* ═══ ANIMATION: Pause & Resume (light) ═══ */
  .anim-pause-resume {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .anim-pause-resume .timeline-track {
    position: absolute;
    top: 50%;
    left: 10%;
    right: 10%;
    height: 2px;
    background: rgba(26,23,20,0.1);
    transform: translateY(-50%);
  }

  .anim-pause-resume .progress-fill {
    position: absolute;
    top: 50%;
    left: 10%;
    height: 2px;
    background: var(--color-accent);
    transform: translateY(-50%);
    transition: width 0.5s ease;
    opacity: 0.5;
  }

  .anim-pause-resume .pr-step {
    position: absolute;
    top: 50%;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-surface-warm);
    border: 1.5px solid rgba(26,23,20,0.15);
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-muted);
    transition: all 0.4s ease;
    z-index: 2;
  }

  .pr-step.completed {
    border-color: var(--color-accent);
    background: rgba(241,120,41,0.1);
    color: var(--color-accent);
  }

  .pr-step.active {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: #FFFFFF;
    box-shadow: 0 0 20px rgba(241,120,41,0.3);
    transform: translate(-50%, -50%) scale(1.15);
  }

  .pr-step.paused {
    border-color: #E8A840;
    background: rgba(232,168,64,0.1);
    color: #E8A840;
    animation: pausePulse 1.5s ease infinite;
  }

  .human-badge {
    position: absolute;
    top: 18%;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(232,168,64,0.12);
    border: 1px solid rgba(232,168,64,0.3);
    border-radius: 12px;
    padding: 6px 14px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: #E8A840;
    opacity: 0;
    transition: opacity 0.4s;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .human-badge.visible {
    opacity: 1;
  }

  /* ═══ ANIMATION: Replay (light) ═══ */
  .anim-replay {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .replay-row {
    position: absolute;
    top: 45%;
    left: 8%;
    right: 8%;
    display: flex;
    align-items: center;
    gap: 6px;
    transform: translateY(-50%);
  }

  .rstep {
    flex: 1;
    height: 40px;
    border-radius: 6px;
    background: var(--color-surface-warm);
    border: 1px solid rgba(26,23,20,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-muted);
    transition: all 0.3s ease;
  }

  .rstep.ok {
    border-color: rgba(61,140,92,0.4);
    background: rgba(61,140,92,0.08);
    color: var(--color-success);
  }

  .rstep.fail {
    border-color: var(--color-cost-up);
    background: rgba(220,74,61,0.08);
    color: var(--color-cost-up);
    animation: failShake 0.4s ease;
  }

  @keyframes failShake {
    0%, 100% { transform: translateX(0); }
    20% { transform: translateX(-3px); }
    40% { transform: translateX(3px); }
    60% { transform: translateX(-2px); }
    80% { transform: translateX(2px); }
  }

  .rstep.replay {
    border-color: var(--color-accent);
    background: rgba(241,120,41,0.08);
    color: var(--color-accent);
    box-shadow: 0 0 12px rgba(241,120,41,0.15);
  }

  .replay-status {
    position: absolute;
    bottom: 18%;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-muted);
    white-space: nowrap;
    transition: all 0.3s;
  }

  .replay-status.error { color: var(--color-cost-up); }
  .replay-status.success { color: var(--color-success); }

  .cost-saved {
    position: absolute;
    top: 15%;
    right: 10%;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-success);
    opacity: 0;
    transition: opacity 0.4s;
  }

  .cost-saved.visible { opacity: 1; }

  /* ═══ ANIMATION: Framework Orbit (light) ═══ */
  .anim-framework {
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .kitaru-core {
    width: 90px;
    height: 90px;
    border: 2px solid var(--color-accent);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-accent);
    letter-spacing: 0.1em;
    position: relative;
    z-index: 2;
    background: var(--color-surface-warm);
  }

  .framework-orbit {
    position: absolute;
    width: 240px;
    height: 240px;
    border: 1px dashed rgba(26,23,20,0.1);
    border-radius: 50%;
  }

  .fw-item {
    position: absolute;
    background: var(--color-surface-warm);
    border: 1px solid rgba(26,23,20,0.1);
    border-radius: 8px;
    padding: 6px 14px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-muted);
    white-space: nowrap;
    transition: all 0.5s ease;
  }

  .fw-item.active {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: rgba(241,120,41,0.06);
  }

  /* ═══ ANIMATION: Parallel Branches (light) ═══ */
  .anim-parallel {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .par-source {
    position: absolute;
    left: 12%;
    top: 50%;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--color-accent);
    transform: translateY(-50%);
    z-index: 2;
  }

  .par-branch {
    position: absolute;
    left: 18%;
    right: 12%;
    height: 2px;
    display: flex;
    align-items: center;
  }

  .par-branch[data-idx="0"] { top: 28%; }
  .par-branch[data-idx="1"] { top: 50%; }
  .par-branch[data-idx="2"] { top: 72%; }

  .par-line {
    position: absolute;
    left: 0;
    right: 0;
    height: 2px;
    background: rgba(26,23,20,0.08);
  }

  .par-dot {
    position: absolute;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--color-surface-warm);
    border: 1.5px solid rgba(26,23,20,0.15);
    transition: all 0.4s ease;
    z-index: 2;
  }

  .par-dot[data-dot="0"] { left: 20%; }
  .par-dot[data-dot="1"] { left: 50%; }
  .par-dot[data-dot="2"] { left: 80%; }

  .par-dot.ok {
    border-color: rgba(61,140,92,0.6);
    background: oklch(0.93 0.03 155);
  }

  .par-dot.fail {
    border-color: var(--color-cost-up);
    background: oklch(0.93 0.03 25);
    animation: failShake 0.4s ease;
  }

  .par-dot.replay {
    border-color: var(--color-accent);
    background: oklch(0.93 0.03 55);
    box-shadow: 0 0 8px rgba(241,120,41,0.2);
  }

  /* Content-box spacer — extends the sticky container so the last
     card has enough scroll runway to fully reach its sticky position. */
  .sticky-runway {
    height: 5vh;
    pointer-events: none;
  }

  /* ═══ Mobile responsive (< 768px) ═══ */
  @media (max-width: 768px) {
    .features-header {
      padding: 48px 16px 32px;
    }

    .features-sticky-container {
      padding: 0 16px;
    }

    .sticky-runway {
      display: none;
    }

    .feature-card {
      position: relative;
      top: auto !important;
      min-height: auto;
      margin-bottom: 32px;
    }

    .feature-card.faded .feature-card-inner {
      opacity: 1;
    }

    .feature-card--last {
      margin-bottom: 0;
    }

    .feature-card-inner {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .feature-text {
      padding: 28px 24px;
    }

    .feature-visual {
      aspect-ratio: 16/10;
      border-left: none;
      border-top: 1px solid var(--color-border);
      border-radius: 0 0 15px 15px;
    }

    .feature-card h3 {
      font-size: 1.15rem;
    }

    .feature-card p {
      max-width: none;
    }
  }

  @media (max-width: 480px) {
    .feature-text {
      padding: 24px 20px;
    }
    .feature-card h3 { font-size: 1.05rem; }
    .feature-card p { font-size: 0.88rem; }
    .feature-visual { aspect-ratio: 16/9; }
  }
</style>

<script>
  // ═══ Card hover glow tracking ═══
  document.querySelectorAll<HTMLElement>('.feature-card').forEach(card => {
    card.addEventListener('mousemove', (event) => {
      const e = event as MouseEvent;
      const rect = card.getBoundingClientRect();
      card.style.setProperty('--mouse-x', ((e.clientX - rect.left) / rect.width * 100) + '%');
      card.style.setProperty('--mouse-y', ((e.clientY - rect.top) / rect.height * 100) + '%');
    });
    card.addEventListener('mouseleave', () => {
      card.style.setProperty('--mouse-x', '50%');
      card.style.setProperty('--mouse-y', '50%');
    });
  });

  // ═══ Per-card animation system ═══
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Timer arrays per card
  const animTimers: number[][] = [[], [], [], []];

  function scheduleTimer(cardIdx: number, fn: () => void, delay: number): number {
    const id = setTimeout(() => {
      const arr = animTimers[cardIdx];
      const idx = arr.indexOf(id);
      if (idx !== -1) arr.splice(idx, 1);
      fn();
    }, delay) as unknown as number;
    animTimers[cardIdx].push(id);
    return id;
  }

  function clearCardTimers(cardIdx: number) {
    animTimers[cardIdx].forEach(id => clearTimeout(id));
    animTimers[cardIdx] = [];
  }

  // Animation starter functions — each takes its card index for timer tracking
  function runPauseResumeAnim(ci: number) {
    const container = document.getElementById('animPause');
    if (!container) return;
    const steps = container.querySelectorAll('.pr-step');
    const badge = document.getElementById('humanBadge');
    const progress = document.getElementById('progressFill');

    steps.forEach(s => { s.className = 'pr-step'; });
    badge?.classList.remove('visible');
    if (progress) progress.style.width = '0%';

    const positions = [15, 30, 45, 60, 75, 90];
    let i = 0;

    function nextStep() {
      if (i < steps.length) {
        if (i > 0) { steps[i-1].classList.remove('active'); steps[i-1].classList.add('completed'); }
        steps[i].classList.add('active');
        if (progress) progress.style.width = (positions[i] - positions[0] + 2) + '%';

        if (i === 3) {
          scheduleTimer(ci, () => {
            steps[i].classList.remove('active');
            steps[i].classList.add('paused');
            badge?.classList.add('visible');
            scheduleTimer(ci, () => {
              badge?.classList.remove('visible');
              steps[i].classList.remove('paused');
              steps[i].classList.add('completed');
              i++;
              nextStep();
            }, 2000);
          }, 600);
        } else {
          scheduleTimer(ci, () => { i++; nextStep(); }, 600);
        }
      } else {
        steps[steps.length - 1].classList.remove('active');
        steps[steps.length - 1].classList.add('completed');
        if (progress) progress.style.width = '82%';
        scheduleTimer(ci, () => runPauseResumeAnim(ci), 2000);
      }
    }
    scheduleTimer(ci, nextStep, 500);
  }

  function runReplayAnim(ci: number) {
    const container = document.getElementById('animReplay');
    if (!container) return;
    const steps = container.querySelectorAll('.rstep');
    const status = document.getElementById('replayStatus');
    const cost = document.getElementById('costSaved');

    steps.forEach(s => { s.className = 'rstep'; });
    if (status) { status.textContent = 'Running agent...'; status.className = 'replay-status'; }
    cost?.classList.remove('visible');

    let i = 0;
    function nextRStep() {
      if (i < steps.length) {
        if (i === 5) {
          steps[i].classList.add('fail');
          if (status) { status.textContent = '\u2717 Step 6 failed \u2014 API timeout'; status.classList.add('error'); }
          scheduleTimer(ci, () => {
            if (status) { status.textContent = '\u21BB Replaying from step 6...'; status.className = 'replay-status'; }
            steps[i].className = 'rstep';
            scheduleTimer(ci, () => {
              steps[i].classList.add('replay');
              cost?.classList.add('visible');
              scheduleTimer(ci, () => {
                steps[i].classList.remove('replay');
                steps[i].classList.add('ok');
                i++;
                nextRStep();
              }, 800);
            }, 600);
          }, 1500);
        } else {
          steps[i].classList.add('ok');
          i++;
          scheduleTimer(ci, nextRStep, 350);
        }
      } else {
        if (status) { status.textContent = '\u2713 All steps complete'; status.classList.add('success'); }
        scheduleTimer(ci, () => runReplayAnim(ci), 2500);
      }
    }
    scheduleTimer(ci, nextRStep, 500);
  }

  function runFrameworkAnim(ci: number) {
    const container = document.getElementById('animFramework');
    if (!container) return;
    const items = container.querySelectorAll('.fw-item');
    let current = 0;

    function highlight() {
      items.forEach(it => it.classList.remove('active'));
      items[current].classList.add('active');
      current = (current + 1) % items.length;
      scheduleTimer(ci, highlight, 1500);
    }
    scheduleTimer(ci, highlight, 800);
  }

  function runParallelAnim(ci: number) {
    const container = document.getElementById('animParallel');
    if (!container) return;
    const branches = container.querySelectorAll('.par-branch');
    const allDots = container.querySelectorAll('.par-dot');

    allDots.forEach(d => { d.className = 'par-dot'; });

    let step = 0;
    const failBranch = 2;
    const failDot = 1;

    function nextStep() {
      if (step < 3) {
        branches.forEach((branch, bIdx) => {
          const dot = branch.querySelector(`.par-dot[data-dot="${step}"]`);
          if (!dot) return;
          if (bIdx === failBranch && step === failDot) {
            scheduleTimer(ci, () => {
              dot.classList.add('fail');
              scheduleTimer(ci, () => {
                dot.classList.remove('fail');
                dot.classList.add('replay');
                scheduleTimer(ci, () => {
                  dot.classList.remove('replay');
                  dot.classList.add('ok');
                  step++;
                  nextStep();
                }, 600);
              }, 800);
            }, 200);
          } else {
            dot.classList.add('ok');
          }
        });
        if (!(failBranch >= 0 && step === failDot)) {
          step++;
          scheduleTimer(ci, nextStep, 500);
        }
      } else {
        scheduleTimer(ci, () => runParallelAnim(ci), 2500);
      }
    }
    scheduleTimer(ci, nextStep, 500);
  }

  const animStarters = [runPauseResumeAnim, runReplayAnim, runFrameworkAnim, runParallelAnim];

  function resetAnimState(cardIdx: number) {
    clearCardTimers(cardIdx);
    if (cardIdx === 0) {
      const container = document.getElementById('animPause');
      if (container) {
        container.querySelectorAll('.pr-step').forEach(s => { s.className = 'pr-step'; });
        document.getElementById('humanBadge')?.classList.remove('visible');
        const pf = document.getElementById('progressFill');
        if (pf) pf.style.width = '0%';
      }
    } else if (cardIdx === 1) {
      const container = document.getElementById('animReplay');
      if (container) {
        container.querySelectorAll('.rstep').forEach(s => { s.className = 'rstep'; });
        const status = document.getElementById('replayStatus');
        if (status) { status.textContent = 'Running agent...'; status.className = 'replay-status'; }
        document.getElementById('costSaved')?.classList.remove('visible');
      }
    } else if (cardIdx === 2) {
      const container = document.getElementById('animFramework');
      if (container) {
        container.querySelectorAll('.fw-item').forEach(it => it.classList.remove('active'));
      }
    } else if (cardIdx === 3) {
      const container = document.getElementById('animParallel');
      if (container) {
        container.querySelectorAll('.par-dot').forEach(d => { d.className = 'par-dot'; });
      }
    }
  }

  function setActiveCard(cards: NodeListOf<HTMLElement>, nextIdx: number, activeIdxRef: { value: number }) {
    if (nextIdx === activeIdxRef.value) return;

    if (activeIdxRef.value >= 0) {
      resetAnimState(activeIdxRef.value);
    }

    activeIdxRef.value = nextIdx;

    if (nextIdx >= 0) {
      animStarters[nextIdx](nextIdx);
    }

    cards.forEach((card, idx) => {
      if (idx < nextIdx) {
        card.classList.add('faded');
      } else {
        card.classList.remove('faded');
      }
    });
  }

  function setupDesktopActivation(
    section: HTMLElement,
    cards: NodeListOf<HTMLElement>,
    activeIdxRef: { value: number }
  ): () => void {
    let ticking = false;
    const controller = new AbortController();

    function computeStickyLine(card: HTMLElement): number {
      const topPx = Number.parseFloat(window.getComputedStyle(card).top);
      if (!Number.isNaN(topPx)) return topPx;
      return window.innerHeight * 0.15;
    }

    function updateActiveCard() {
      if (ticking) return;
      ticking = true;

      requestAnimationFrame(() => {
        ticking = false;

        const firstCard = cards[0];
        if (!firstCard) return;

        const stickyLine = computeStickyLine(firstCard);
        const sectionRect = section.getBoundingClientRect();

        // Section is not in sticky range yet.
        if (sectionRect.top > stickyLine) {
          setActiveCard(cards, -1, activeIdxRef);
          return;
        }

        // Select the highest-index card that has reached its sticky threshold.
        let nextIdx = -1;
        cards.forEach((card, idx) => {
          const topPx = computeStickyLine(card);
          const rect = card.getBoundingClientRect();
          if (rect.top <= topPx + 1) {
            nextIdx = idx;
          }
        });

        setActiveCard(cards, nextIdx, activeIdxRef);
      });
    }

    window.addEventListener('scroll', updateActiveCard, { passive: true, signal: controller.signal });
    window.addEventListener('resize', updateActiveCard, { passive: true, signal: controller.signal });

    // Initialize immediately for refresh/deep-link/restored scroll positions.
    updateActiveCard();

    return () => {
      controller.abort();
      setActiveCard(cards, -1, activeIdxRef);
    };
  }

  function setupMobileActivation(
    cards: NodeListOf<HTMLElement>,
    activeIdxRef: { value: number }
  ): () => void {
    const mobileObs = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        const card = entry.target as HTMLElement;
        const idx = Number.parseInt(card.getAttribute('data-feature') || '-1', 10);
        if (idx < 0) return;

        if (entry.isIntersecting) {
          setActiveCard(cards, idx, activeIdxRef);
        } else if (activeIdxRef.value === idx) {
          setActiveCard(cards, -1, activeIdxRef);
        }
      });
    }, { threshold: 0.35 });

    cards.forEach(card => mobileObs.observe(card));

    return () => {
      mobileObs.disconnect();
      setActiveCard(cards, -1, activeIdxRef);
      cards.forEach((_, idx) => resetAnimState(idx));
    };
  }

  if (!prefersReducedMotion) {
    const section = document.querySelector<HTMLElement>('#how-it-works');
    const cards = document.querySelectorAll<HTMLElement>('.feature-card');
    const mobileQuery = window.matchMedia('(max-width: 767px)');
    const activeIdxRef = { value: -1 };

    if (section && cards.length) {
      const sectionEl = section;
      let teardownActivation: (() => void) | null = null;

      function mountActivationMode() {
        teardownActivation?.();
        teardownActivation = mobileQuery.matches
          ? setupMobileActivation(cards, activeIdxRef)
          : setupDesktopActivation(sectionEl, cards, activeIdxRef);
      }

      mountActivationMode();

      const handleModeChange = () => mountActivationMode();
      mobileQuery.addEventListener('change', handleModeChange);

      window.addEventListener('pagehide', () => {
        mobileQuery.removeEventListener('change', handleModeChange);
        teardownActivation?.();
      }, { once: true });
    }
  }
</script>
