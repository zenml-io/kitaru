---
// SocialProof.astro — Lineage proof, shipped-capability proof, and background links
---

<section id="social-proof" class="social-proof-section">
  <div class="social-proof-inner">
    <h2 class="sr-only">Foundations and proof for Kitaru</h2>

    <div class="sp-header" data-reveal>
      <span class="section-eyebrow">FOUNDATIONS & PROOF</span>
      <div class="sp-companies">
        <span class="sp-label">ZenML lineage</span>
        <a class="sp-company" href="https://www.zenml.io/case-study/jetbrains" target="_blank" rel="noopener">JetBrains</a>
        <span class="sp-sep" aria-hidden="true"></span>
        <a class="sp-company" href="https://www.zenml.io/case-study/adeo-leroy-merlin" target="_blank" rel="noopener">Adeo</a>
        <span class="sp-sep" aria-hidden="true"></span>
        <a class="sp-company" href="https://www.zenml.io/case-study/brevo" target="_blank" rel="noopener">Brevo</a>
      </div>
    </div>

    <p class="sp-tagline" data-reveal data-reveal-delay="1">
      Kitaru inherits production-proven orchestration foundations from ZenML and draws on lessons from real AI systems. Kitaru's own claims stay narrow and concrete: durable execution, replay, wait/resume, durable memory, and portability are shipped today.
    </p>

    <div class="sp-stats">
      <div class="sp-stat" data-reveal="scale-up" data-reveal-delay="2">
        <div class="sp-stat-accent" aria-hidden="true"></div>
        <span class="sp-stat-number" data-count-to="5" data-suffix="+">5+</span>
        <span class="sp-stat-unit">years of ZenML lineage</span>
        <span class="sp-stat-desc">These reference customers are lineage proof for the orchestration foundations underneath Kitaru &mdash; not direct Kitaru adoption proof.</span>
      </div>

      <div class="sp-stat" data-reveal="scale-up" data-reveal-delay="3">
        <div class="sp-stat-accent" aria-hidden="true"></div>
        <span class="sp-stat-number sp-stat-text">Shipped</span>
        <span class="sp-stat-unit">in Kitaru today</span>
        <span class="sp-stat-desc">Checkpointed execution, replay from failure, human-in-the-loop wait/resume, durable memory, framework portability, and infrastructure portability are live product capabilities.</span>
      </div>
    </div>

    <div class="sp-links" data-reveal data-reveal-delay="4">
      <span class="sp-links-label">Background and research</span>
      <div class="sp-links-list">
        <a class="sp-proof-link" href="/blog/from-zenml-to-kitaru">From ZenML to Kitaru</a>
        <a class="sp-proof-link" href="/blog/why-agents-need-durable-execution">Why agents need durable execution</a>
        <a class="sp-proof-link" href="/blog/agents-need-more-than-traces">Why agents need more than traces</a>
      </div>
    </div>
  </div>
</section>

<style>
  .social-proof-section {
    background: var(--color-accent-light);
    padding: 120px 0;
    position: relative;
    overflow: hidden;
  }

  .social-proof-section::before {
    content: '';
    position: absolute;
    top: 0;
    right: -10%;
    width: 60%;
    height: 100%;
    background: radial-gradient(ellipse at 70% 30%, oklch(0.65 0.16 45 / 0.04) 0%, transparent 70%);
    pointer-events: none;
  }

  .social-proof-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(24px, 5vw, 80px);
    position: relative;
  }

  .sp-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 20px;
  }

  .sp-companies {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
  }

  .sp-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .sp-company {
    font-family: var(--font-ui);
    font-size: 13px;
    font-weight: 600;
    color: var(--color-primary);
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .sp-company:hover {
    opacity: 0.7;
  }

  .sp-sep {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--color-accent);
    flex-shrink: 0;
  }

  .sp-tagline {
    font-size: clamp(26px, 3.5vw, 42px);
    font-weight: 600;
    color: var(--color-primary);
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin: 0 0 56px;
    max-width: 860px;
  }

  .sp-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: oklch(0.15 0.02 60 / 0.08);
    border-radius: 16px;
    overflow: hidden;
  }

  .sp-stat {
    background: var(--color-surface);
    padding: 40px 36px;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .sp-stat-accent {
    position: absolute;
    top: 0;
    left: 36px;
    right: 36px;
    height: 2px;
    background: linear-gradient(90deg, var(--color-accent), oklch(0.68 0.08 55));
    border-radius: 0 0 2px 2px;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .sp-stat:hover .sp-stat-accent {
    opacity: 1;
  }

  .sp-stat-number {
    font-size: clamp(56px, 7vw, 80px);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--color-primary);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .sp-stat-text {
    font-size: clamp(36px, 4.5vw, 52px);
    letter-spacing: -0.03em;
  }

  .sp-stat-unit {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-top: 4px;
    margin-bottom: 16px;
  }

  .sp-stat-desc {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--color-secondary);
    font-weight: 300;
    max-width: 360px;
  }

  .sp-links {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .sp-links-label {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .sp-links-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .sp-proof-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 14px;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-primary);
    text-decoration: none;
    font-size: 0.85rem;
    transition: border-color 0.2s, transform 0.2s, background 0.2s;
  }

  .sp-proof-link::after {
    content: '→';
    color: var(--color-accent);
  }

  .sp-proof-link:hover {
    border-color: oklch(0.65 0.16 45 / 0.3);
    background: oklch(1 0 0 / 0.8);
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .social-proof-section {
      padding: 80px 0;
    }

    .sp-tagline {
      font-size: 22px;
      line-height: 1.25;
      margin-bottom: 40px;
    }

    .sp-stats {
      grid-template-columns: 1fr;
    }

    .sp-stat {
      padding: 32px 28px;
    }

    .sp-stat-number {
      font-size: 52px;
    }

    .sp-stat-text {
      font-size: 32px;
    }

    .sp-stat-accent {
      left: 28px;
      right: 28px;
    }
  }

  @media (max-width: 480px) {
    .social-proof-section { padding: 60px 0; }
    .sp-tagline { font-size: 19px; margin-bottom: 32px; }
    .sp-stat { padding: 24px 20px; }
    .sp-stat-number { font-size: 44px; }
    .sp-stat-text { font-size: 28px; }
    .sp-stat-accent { left: 20px; right: 20px; }
  }
</style>

<script>
  const counters = document.querySelectorAll<HTMLElement>('.sp-stat-number[data-count-to]');
  if (counters.length && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.countTo ?? '0', 10);
        const suffix = el.dataset.suffix ?? '';
        const duration = 1200;
        const start = performance.now();

        function tick(now: number) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const current = Math.round(eased * target);
          el.textContent = current + suffix;
          if (progress < 1) requestAnimationFrame(tick);
        }

        requestAnimationFrame(tick);
        observer.unobserve(el);
      });
    }, { threshold: 0.5 });

    counters.forEach(el => observer.observe(el));
  }
</script>
