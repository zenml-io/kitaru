---
// WhyKitaru.astro — Three value proposition cards
---

<section id="why-kitaru" class="section-pad">
  <div class="section-inner">
    <span class="section-eyebrow" data-reveal>WHY KITARU</span>
    <h2 class="section-title" data-reveal data-reveal-delay="1">Why teams choose Kitaru</h2>

    <div class="why-grid">

      <div class="why-card" data-reveal="scale-up" data-reveal-delay="2">
        <div class="card-glow"></div>
        <div class="why-card-image">
          <img src="https://assets.kitaru.ai/content/site/735fb438/k-feat-3.avif" alt="Deployment flexibility" loading="lazy" />
        </div>
        <div class="why-card-content">
          <h3>Deployment flexibility</h3>
          <p>Same Python code runs locally, on Kubernetes, or across AWS, GCP, and Azure. Switch stacks with one command.</p>
        </div>
      </div>

      <div class="why-card" data-reveal="scale-up" data-reveal-delay="3">
        <div class="card-glow"></div>
        <div class="why-card-image">
          <img src="https://assets.kitaru.ai/content/site/5e721b4d/k-feat-2.avif" alt="Full execution control" loading="lazy" />
        </div>
        <div class="why-card-content">
          <h3>Full execution control</h3>
          <p>Pause at decision points, get human input, and resume — hours or days later. Replay from any checkpoint without re-running everything.</p>
        </div>
      </div>

      <div class="why-card" data-reveal="scale-up" data-reveal-delay="4">
        <div class="card-glow"></div>
        <div class="why-card-image">
          <img src="https://assets.kitaru.ai/content/site/b63a92fd/k-feat-1.avif" alt="Python-first, no lock-in" loading="lazy" />
        </div>
        <div class="why-card-content">
          <h3>Python-first, no lock-in</h3>
          <p>Wrap any Python agent framework — PydanticAI, CrewAI, or raw code — with Kitaru decorators. No DSL to learn, no vendor lock-in.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .why-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 48px;
  }

  .why-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s;
  }

  .why-card:hover {
    border-color: var(--color-muted);
  }

  .card-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: radial-gradient(circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(241,120,41,0.04), transparent 60%);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s;
    z-index: 1;
  }

  .why-card:hover .card-glow {
    opacity: 1;
  }

  .why-card-image {
    width: 100%;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface-warm, oklch(0.97 0.005 70));
  }

  .image-placeholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--color-surface-warm, oklch(0.97 0.005 70));
  }

  .why-card-image img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    display: block;
  }

  .why-card-content {
    position: relative;
    z-index: 2;
    padding: 24px 28px 28px;
  }

  .why-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .why-card p {
    color: var(--color-secondary);
    font-size: 0.85rem;
    line-height: 1.6;
    font-weight: 300;
  }

  @media (max-width: 768px) {
    .why-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  document.querySelectorAll('.why-card').forEach(card => {
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = (card as HTMLElement).getBoundingClientRect();
      (card as HTMLElement).style.setProperty('--mouse-x', ((e.clientX - rect.left) / rect.width * 100) + '%');
      (card as HTMLElement).style.setProperty('--mouse-y', ((e.clientY - rect.top) / rect.height * 100) + '%');
    });
    card.addEventListener('mouseleave', () => {
      (card as HTMLElement).style.setProperty('--mouse-x', '50%');
      (card as HTMLElement).style.setProperty('--mouse-y', '50%');
    });
  });
</script>
