---
// Hero.astro — Centered hero with ASCII canvas + mesh gradient background
---

<section class="hero-section" id="hero">
  <canvas class="ascii-canvas" aria-hidden="true"></canvas>
  <div class="mesh-gradient" aria-hidden="true">
    <div class="mesh-blob mesh-blob-1"></div>
    <div class="mesh-blob mesh-blob-2"></div>
    <div class="mesh-blob mesh-blob-3"></div>
  </div>

  <div class="hero-content">
    <div class="hero-badges" data-reveal>
      <span class="pill-badge">
        <span class="pulse-dot"></span>
        From the makers of ZenML
      </span>
      <span class="pill-badge">
        Early access &rarr; March 2026
      </span>
    </div>

    <h1 class="hero-headline" data-reveal data-reveal-delay="1">
      You build your agents.<br>We make them <span class="hero-accent">durable</span>.
    </h1>

    <p class="hero-subtitle" data-reveal data-reveal-delay="2">
      Production-grade reliability for Python agents. Any framework. Any cloud. No&nbsp;rewrite.
    </p>

    <div class="hero-buttons" data-reveal data-reveal-delay="3">
      <a href="/#cta" class="btn-primary">Get early access</a>
      <a href="https://github.com/zenml-io/kitaru" target="_blank" rel="noopener" class="btn-secondary hero-gh-btn">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        View on GitHub
      </a>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px clamp(24px, 5vw, 80px) 60px;
    overflow: hidden;
  }

  .ascii-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  /* ─── Mesh gradient ─── */
  .mesh-gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }

  .mesh-blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    will-change: transform;
  }

  .mesh-blob-1 {
    width: 800px;
    height: 800px;
    top: -20%;
    left: -15%;
    background: radial-gradient(circle, rgba(241,120,41,0.20) 0%, transparent 70%);
    animation: meshFloat1 10s ease-in-out infinite alternate;
  }

  .mesh-blob-2 {
    width: 700px;
    height: 700px;
    bottom: -25%;
    right: -15%;
    background: radial-gradient(circle, rgba(196,149,106,0.16) 0%, transparent 70%);
    animation: meshFloat2 13s ease-in-out infinite alternate;
  }

  .mesh-blob-3 {
    width: 600px;
    height: 600px;
    top: 20%;
    left: 30%;
    background: radial-gradient(circle, rgba(241,120,41,0.14) 0%, transparent 70%);
    animation: meshFloat3 8s ease-in-out infinite alternate;
  }

  @keyframes meshFloat1 {
    0%   { transform: translate(0, 0) scale(1); }
    25%  { transform: translate(20%, 12%) scale(1.2); }
    50%  { transform: translate(-8%, 25%) scale(0.9); }
    75%  { transform: translate(15%, -8%) scale(1.15); }
    100% { transform: translate(-5%, 15%) scale(1.05); }
  }

  @keyframes meshFloat2 {
    0%   { transform: translate(0, 0) scale(1); }
    25%  { transform: translate(-18%, -10%) scale(1.15); }
    50%  { transform: translate(12%, -20%) scale(0.85); }
    75%  { transform: translate(-10%, 8%) scale(1.1); }
    100% { transform: translate(8%, -12%) scale(0.95); }
  }

  @keyframes meshFloat3 {
    0%   { transform: translate(0, 0) scale(1); }
    33%  { transform: translate(-25%, 20%) scale(1.25); }
    66%  { transform: translate(20%, -15%) scale(0.85); }
    100% { transform: translate(-10%, 5%) scale(1.1); }
  }

  .hero-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 800px;
    width: 100%;
  }

  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    margin-bottom: 32px;
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: pulse-dot 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(241,120,41,0.4); }
    50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(241,120,41,0); }
  }

  .hero-headline {
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 700;
    line-height: 1.06;
    letter-spacing: -0.04em;
    margin: 0 0 24px;
    color: var(--color-primary);
  }

  .hero-accent {
    color: var(--color-accent);
  }

  .hero-subtitle {
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    font-weight: 300;
    line-height: 1.65;
    color: var(--color-secondary);
    max-width: 560px;
    margin: 0 0 40px;
  }

  .hero-buttons {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-gh-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  @media (max-width: 768px) {
    .ascii-canvas {
      display: none;
    }

    .hero-section {
      min-height: 100dvh;
      padding: 60px 24px 48px;
    }

    .hero-headline {
      font-size: clamp(2.2rem, 8vw, 3rem);
    }

    .hero-buttons {
      flex-direction: column;
      width: 100%;
      max-width: 320px;
    }

    .hero-buttons .btn-primary,
    .hero-buttons .btn-secondary {
      width: 100%;
      justify-content: center;
      text-align: center;
    }

    .mesh-blob-1 { width: 300px; height: 300px; }
    .mesh-blob-2 { width: 250px; height: 250px; }
    .mesh-blob-3 { width: 200px; height: 200px; }
  }

  @media (max-width: 480px) {
    .hero-section {
      padding: 48px 16px 36px;
    }

    .hero-badges {
      margin-bottom: 24px;
    }

    .hero-headline {
      font-size: clamp(2rem, 7vw, 2.6rem);
      margin-bottom: 18px;
    }

    .hero-subtitle {
      font-size: 0.95rem;
      margin-bottom: 32px;
    }

    .pill-badge {
      font-size: 0.7rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pulse-dot {
      animation: none;
    }

    .mesh-blob {
      animation: none;
    }
  }
</style>

<script>
  // ─── ASCII Canvas Background — Landscape zones ───
  (() => {
  const canvas = document.querySelector<HTMLCanvasElement>('.ascii-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  const GRID_SPACING = 6;
  const DOT_RADIUS = 2;
  const CURSOR_RADIUS = 220;
  const ATTRACTOR_RADIUS = 260;
  const DPR = Math.min(window.devicePixelRatio || 1, 2);

  // Landscape tuning
  const RIDGE_BASE = 0.72;
  const RIDGE_AMP = [0.06, 0.03, 0.015];
  const CLOUD_BAND = 0.12;
  const CLOUD_THRESHOLD = 0.45;
  const CENTER_SUPPRESS = 0.45;

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  type Zone = 'sky' | 'cloud' | 'mountain';

  interface CharCell {
    x: number;
    y: number;
    phase: number;
    baseOpacity: number;
    r: number;
    g: number;
    b: number;
    zone: Zone;
    colorStr: string;
  }

  let cells: CharCell[] = [];
  let mouseX = -9999;
  let mouseY = -9999;
  let mouseActive = false;
  let animId = 0;
  let canvasW = 0;
  let canvasH = 0;

  // Procedural ridgeline — 3 layered sine waves per column
  function ridgelineAt(col: number, totalCols: number): number {
    const nx = col / totalCols;
    return RIDGE_BASE
      + Math.sin(nx * Math.PI * 2.3 + 0.8) * RIDGE_AMP[0]
      + Math.sin(nx * Math.PI * 5.1 + 2.1) * RIDGE_AMP[1]
      + Math.sin(nx * Math.PI * 11.7 + 4.3) * RIDGE_AMP[2];
  }

  // Cloud clumpiness via cheap sine noise
  function cloudNoise(col: number, row: number): number {
    return (Math.sin(col * 0.7 + row * 1.3) * 0.5 + 0.5)
      * (Math.cos(col * 1.1 - row * 0.9 + 2.7) * 0.5 + 0.5);
  }

  // Linear interpolation helper
  function lerp(a: number, b: number, t: number): number {
    return a + (b - a) * t;
  }

  function buildGrid() {
    cells = [];
    canvasW = canvas!.width / DPR;
    canvasH = canvas!.height / DPR;
    const cols = Math.ceil(canvasW / GRID_SPACING) + 1;
    const rows = Math.ceil(canvasH / GRID_SPACING) + 1;
    const cx = canvasW / 2;
    const cy = canvasH / 2;

    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const x = c * GRID_SPACING;
        const y = r * GRID_SPACING;
        const ny = r / rows; // normalized Y (0 = top, 1 = bottom)
        const ridge = ridgelineAt(c, cols);
        const cloudTop = ridge - CLOUD_BAND;

        // Zone classification
        let zone: Zone;
        let cr: number, cg: number, cb: number;
        let base: number;

        // Smooth blend: 0 = pure sky, 1 = pure mountain
        const FADE_BAND = 0.06;
        const blendCenter = (cloudTop + ridge) / 2;
        const blendHalf = Math.max((ridge - cloudTop) / 2 + FADE_BAND, 0.01);
        const rawBlend = (ny - blendCenter + blendHalf) / (blendHalf * 2);
        const cb2 = Math.max(0, Math.min(rawBlend, 1));
        const blend = cb2 * cb2 * (3 - 2 * cb2); // smoothstep

        // Sky: warm peach
        const skyT = Math.min(ny / Math.max(cloudTop, 0.01), 1);
        const skyR = lerp(248, 240, skyT);
        const skyG = lerp(220, 195, skyT);
        const skyB = lerp(195, 170, skyT);

        // Mountain: warm peach-orange → burnt orange (brand-aligned)
        const mtnDepth = Math.min(Math.max(0, (ny - ridge) / Math.max(1 - ridge, 0.01)), 1);
        const mtnR = lerp(238, 200, mtnDepth);
        const mtnG = lerp(150, 105, mtnDepth);
        const mtnB = lerp(90, 55, mtnDepth);

        cr = Math.round(lerp(skyR, mtnR, blend));
        cg = Math.round(lerp(skyG, mtnG, blend));
        cb = Math.round(lerp(skyB, mtnB, blend));

        // High contrast: nearly invisible sky, bold mountains
        const skyBase = 0.02 + Math.random() * 0.02;
        const mtnBase = 0.25 + Math.random() * 0.10;
        base = lerp(skyBase, mtnBase, blend);

        if (blend < 0.3) {
          zone = 'sky';
        } else if (blend > 0.7) {
          zone = 'mountain';
        } else {
          zone = 'cloud';
        }

        // Center suppression — smooth radial fade for text readability
        const dist = Math.sqrt((x - cx) ** 2 + ((y - cy) * 1.4) ** 2); // elliptical, wider than tall
        const innerR = Math.min(cx, cy) * 0.2;
        const outerR = Math.min(cx, cy) * 0.55;
        if (dist < outerR) {
          const t = Math.max(0, (dist - innerR) / (outerR - innerR));
          const fade = t * t; // ease-in: fully suppressed at center, smooth ramp out
          base *= CENTER_SUPPRESS + (1 - CENTER_SUPPRESS) * fade;
        }

        cells.push({
          x,
          y,
          phase: Math.random() * Math.PI * 2,
          baseOpacity: base,
          r: cr,
          g: cg,
          b: cb,
          zone,
          colorStr: `rgb(${cr},${cg},${cb})`,
        });
      }
    }
  }

  function resize() {
    const rect = canvas!.parentElement!.getBoundingClientRect();
    canvas!.width = rect.width * DPR;
    canvas!.height = rect.height * DPR;
    canvas!.style.width = rect.width + 'px';
    canvas!.style.height = rect.height + 'px';
    ctx!.setTransform(DPR, 0, 0, DPR, 0, 0);
    buildGrid();
  }

  function drawStatic() {
    ctx!.clearRect(0, 0, canvasW, canvasH);

    for (const cell of cells) {
      ctx!.globalAlpha = cell.baseOpacity;
      ctx!.fillStyle = cell.colorStr;
      ctx!.beginPath();
      ctx!.arc(cell.x, cell.y, DOT_RADIUS, 0, Math.PI * 2);
      ctx!.fill();
    }
    ctx!.globalAlpha = 1;
  }

  function animate(time: number) {
    if (document.hidden) {
      animId = requestAnimationFrame(animate);
      return;
    }

    ctx!.clearRect(0, 0, canvasW, canvasH);

    const t = time * 0.001;

    // Two wandering attractors — always running, Lissajous paths at different speeds
    const at1X = canvasW * 0.5 + Math.sin(t * 0.25) * canvasW * 0.42;
    const at1Y = canvasH * 0.5 + Math.cos(t * 0.18) * canvasH * 0.38;
    const at2X = canvasW * 0.5 + Math.cos(t * 0.15) * canvasW * 0.35;
    const at2Y = canvasH * 0.5 + Math.sin(t * 0.22) * canvasH * 0.32;

    for (const cell of cells) {
      // Ambient breathing — gentle opacity pulse
      const breath = Math.sin(t * 0.6 + cell.phase) * 0.03;
      let opacity = cell.baseOpacity + breath;

      // Attractor 1 — wandering glow (opacity only)
      {
        const adx = cell.x - at1X;
        const ady = cell.y - at1Y;
        const adist = Math.sqrt(adx * adx + ady * ady);
        if (adist < ATTRACTOR_RADIUS) {
          const ratio = 1 - (adist / ATTRACTOR_RADIUS);
          const ease = ratio * ratio;
          opacity = opacity + (0.28 - opacity) * ease;
        }
      }

      // Attractor 2 — secondary wandering glow (opacity only)
      {
        const adx = cell.x - at2X;
        const ady = cell.y - at2Y;
        const adist = Math.sqrt(adx * adx + ady * ady);
        if (adist < ATTRACTOR_RADIUS * 0.8) {
          const ratio = 1 - (adist / (ATTRACTOR_RADIUS * 0.8));
          const ease = ratio * ratio;
          opacity = opacity + (0.22 - opacity) * ease * 0.6;
        }
      }

      // Cursor interaction — opacity boost only
      if (mouseActive) {
        const cdx = cell.x - mouseX;
        const cdy = cell.y - mouseY;
        const cdist = Math.sqrt(cdx * cdx + cdy * cdy);
        if (cdist < CURSOR_RADIUS) {
          const ratio = 1 - (cdist / CURSOR_RADIUS);
          const ease = ratio * ratio;
          opacity = opacity + (0.35 - opacity) * ease;
        }
      }

      ctx!.globalAlpha = Math.max(0.02, Math.min(opacity, 0.35));
      ctx!.fillStyle = cell.colorStr;
      ctx!.beginPath();
      ctx!.arc(cell.x, cell.y, DOT_RADIUS, 0, Math.PI * 2);
      ctx!.fill();
    }

    ctx!.globalAlpha = 1;
    animId = requestAnimationFrame(animate);
  }

  // Mouse tracking
  const heroSection = document.getElementById('hero');

  function updateMouse(clientX: number, clientY: number) {
    const rect = canvas!.getBoundingClientRect();
    mouseX = clientX - rect.left;
    mouseY = clientY - rect.top;
    mouseActive = true;
  }

  heroSection?.addEventListener('mousemove', (e) => updateMouse(e.clientX, e.clientY));
  heroSection?.addEventListener('touchmove', (e) => {
    if (e.touches.length > 0) updateMouse(e.touches[0].clientX, e.touches[0].clientY);
  }, { passive: true });
  heroSection?.addEventListener('mouseleave', () => { mouseActive = false; });
  heroSection?.addEventListener('touchend', () => { mouseActive = false; });

  // Init
  resize();

  if (prefersReducedMotion) {
    drawStatic();
  } else {
    animId = requestAnimationFrame(animate);
  }

  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      resize();
      if (prefersReducedMotion) drawStatic();
    }, 150);
  });
  })();
</script>
