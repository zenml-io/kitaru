---
// Hero.astro — Centered hero with ASCII canvas + mesh gradient background
---

<section class="hero-section" id="hero">
  <canvas class="ascii-canvas" aria-hidden="true"></canvas>
  <div class="mesh-gradient" aria-hidden="true">
    <div class="mesh-blob mesh-blob-1"></div>
    <div class="mesh-blob mesh-blob-2"></div>
    <div class="mesh-blob mesh-blob-3"></div>
  </div>

  <div class="hero-content">
    <div class="hero-badges" data-reveal>
      <span class="pill-badge">
        <span class="pulse-dot"></span>
        From the makers of ZenML
      </span>
      <span class="pill-badge">
        Open source &mdash; Apache 2.0
      </span>
    </div>

    <h1 class="hero-headline" data-reveal data-reveal-delay="1">
      You build your agents.<br>We make them <span class="hero-accent">durable</span>.
    </h1>

    <p class="hero-subtitle" data-reveal data-reveal-delay="2">
      Open-source durable execution for Python agents. Checkpoint, replay, and deploy any framework, any&nbsp;cloud.
    </p>

    <div class="hero-install" data-reveal data-reveal-delay="3">
      <code class="install-cmd">pip install kitaru</code>
      <button class="copy-btn" aria-label="Copy install command" data-copy="pip install kitaru">
        <svg class="copy-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
        <svg class="check-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
      </button>
    </div>

    <div class="hero-buttons" data-reveal data-reveal-delay="4">
      <a href="https://github.com/zenml-io/kitaru" target="_blank" rel="noopener" class="btn-primary hero-gh-btn">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        View on GitHub
      </a>
      <a href="/docs" class="btn-secondary">Read the docs</a>
    </div>
  </div>
</section>

<style>
  .hero-section {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px clamp(24px, 5vw, 80px) 60px;
    overflow: hidden;
  }

  .ascii-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }

  /* ─── Mesh gradient ─── */
  .mesh-gradient {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    overflow: hidden;
  }

  .mesh-blob {
    position: absolute;
    border-radius: 50%;
    will-change: transform;
  }

  .mesh-blob-1 {
    width: 1100px;
    height: 1100px;
    top: -20%;
    left: -15%;
    background: radial-gradient(circle, oklch(0.65 0.16 45 / 0.18) 0%, oklch(0.65 0.16 45 / 0.06) 40%, transparent 65%);
    animation: meshFloat1 10s ease-in-out infinite alternate;
  }

  .mesh-blob-2 {
    width: 1000px;
    height: 1000px;
    bottom: -25%;
    right: -15%;
    background: radial-gradient(circle, oklch(0.68 0.08 55 / 0.14) 0%, oklch(0.68 0.08 55 / 0.05) 40%, transparent 65%);
    animation: meshFloat2 13s ease-in-out infinite alternate;
  }

  .mesh-blob-3 {
    width: 900px;
    height: 900px;
    top: 20%;
    left: 30%;
    background: radial-gradient(circle, oklch(0.65 0.16 45 / 0.12) 0%, oklch(0.65 0.16 45 / 0.04) 40%, transparent 65%);
    animation: meshFloat3 8s ease-in-out infinite alternate;
  }

  @keyframes meshFloat1 {
    0%   { transform: translate(0, 0) scale(1); }
    25%  { transform: translate(20%, 12%) scale(1.2); }
    50%  { transform: translate(-8%, 25%) scale(0.9); }
    75%  { transform: translate(15%, -8%) scale(1.15); }
    100% { transform: translate(-5%, 15%) scale(1.05); }
  }

  @keyframes meshFloat2 {
    0%   { transform: translate(0, 0) scale(1); }
    25%  { transform: translate(-18%, -10%) scale(1.15); }
    50%  { transform: translate(12%, -20%) scale(0.85); }
    75%  { transform: translate(-10%, 8%) scale(1.1); }
    100% { transform: translate(8%, -12%) scale(0.95); }
  }

  @keyframes meshFloat3 {
    0%   { transform: translate(0, 0) scale(1); }
    33%  { transform: translate(-25%, 20%) scale(1.25); }
    66%  { transform: translate(20%, -15%) scale(0.85); }
    100% { transform: translate(-10%, 5%) scale(1.1); }
  }

  .hero-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 800px;
    width: 100%;
  }

  .hero-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    margin-bottom: 32px;
  }

  .pulse-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: pulse-dot 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 oklch(0.65 0.16 45 / 0.4); }
    50% { opacity: 0.7; box-shadow: 0 0 0 6px oklch(0.65 0.16 45 / 0); }
  }

  .hero-headline {
    font-size: clamp(3rem, 6vw, 5rem);
    font-weight: 700;
    line-height: 1.06;
    letter-spacing: -0.04em;
    margin: 0 0 24px;
    color: var(--color-primary);
  }

  .hero-accent {
    color: var(--color-accent);
    background: linear-gradient(
      90deg,
      var(--color-accent) 0%,
      oklch(0.78 0.14 55) 40%,
      var(--color-accent) 80%
    );
    background-size: 200% 100%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: accent-shimmer 4s ease-in-out infinite;
  }

  @keyframes accent-shimmer {
    0%, 100% { background-position: 100% 50%; }
    50% { background-position: 0% 50%; }
  }

  .hero-subtitle {
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    font-weight: 300;
    line-height: 1.65;
    color: var(--color-secondary);
    max-width: 560px;
    margin: 0 0 40px;
  }

  .hero-buttons {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-gh-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  /* Install command */
  .hero-install {
    display: inline-flex;
    align-items: center;
    gap: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 4px 4px 4px 20px;
    margin-bottom: 20px;
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .hero-install:hover {
    border-color: oklch(0.65 0.16 45 / 0.3);
    box-shadow: 0 0 0 3px oklch(0.65 0.16 45 / 0.06);
  }

  .install-cmd {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-primary);
    user-select: all;
    letter-spacing: -0.01em;
  }

  .copy-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    color: var(--color-muted);
    border-radius: 6px;
    cursor: pointer;
    transition: color 0.2s, background 0.2s;
    margin-left: 8px;
    flex-shrink: 0;
  }

  .copy-btn:hover {
    color: var(--color-primary);
    background: oklch(0 0 0 / 0.04);
  }

  .copy-btn .copy-icon,
  .copy-btn .check-icon {
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.15s;
  }

  .copy-btn .check-icon {
    display: none;
    color: var(--color-success);
  }

  .copy-btn.copied .copy-icon {
    display: none;
  }

  .copy-btn.copied .check-icon {
    display: block;
    animation: check-pop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes check-pop {
    0% { transform: scale(0); opacity: 0; }
    60% { transform: scale(1.2); }
    100% { transform: scale(1); opacity: 1; }
  }

  @media (max-width: 768px) {
    .ascii-canvas {
      display: none;
    }

    .hero-section {
      min-height: 100dvh;
      padding: 60px 24px 48px;
    }

    .hero-headline {
      font-size: clamp(2.2rem, 8vw, 3rem);
    }

    .hero-buttons {
      flex-direction: column;
      width: 100%;
      max-width: 320px;
    }

    .hero-buttons .btn-primary,
    .hero-buttons .btn-secondary {
      width: 100%;
      justify-content: center;
      text-align: center;
    }

    .mesh-blob-1 { width: 420px; height: 420px; }
    .mesh-blob-2 { width: 350px; height: 350px; }
    .mesh-blob-3 { width: 280px; height: 280px; }
  }

  @media (max-width: 480px) {
    .hero-section {
      padding: 48px 16px 36px;
    }

    .hero-badges {
      margin-bottom: 24px;
    }

    .hero-headline {
      font-size: clamp(2rem, 7vw, 2.6rem);
      margin-bottom: 18px;
    }

    .hero-subtitle {
      font-size: 0.95rem;
      margin-bottom: 32px;
    }

    .pill-badge {
      font-size: 0.7rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pulse-dot,
    .mesh-blob,
    .hero-accent {
      animation: none;
    }

    .hero-accent {
      -webkit-text-fill-color: var(--color-accent);
      background: none;
    }
  }
</style>

<script>
  // ─── Copy-to-clipboard for Hero install command only ───
  import { copyToClipboard } from '../scripts/clipboard';

  document.querySelectorAll<HTMLButtonElement>('#hero .copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const text = btn.dataset.copy ?? '';
      copyToClipboard(text).then(() => {
        btn.classList.add('copied');
        setTimeout(() => btn.classList.remove('copied'), 1500);
      }).catch(() => {
        btn.setAttribute('aria-label', 'Copy failed');
        setTimeout(() => btn.setAttribute('aria-label', 'Copy install command'), 2000);
      });
    });
  });
</script>

<script>
  // ─── ASCII Canvas Background — Landscape zones ───
  import { sizeCanvasToParent, attachMouseTracker, attachResizeHandler, getAttractorPositions } from '../scripts/canvas-utils';

  (function initHeroCanvas() {
  const canvas = document.querySelector<HTMLCanvasElement>('.ascii-canvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  if (!ctx) return;

  const GRID_SPACING = 6;
  const DOT_RADIUS = 2;
  const CURSOR_RADIUS = 220;
  const ATTRACTOR_RADIUS = 260;
  const DPR = Math.min(window.devicePixelRatio || 1, 2);

  // Landscape tuning
  const RIDGE_BASE = 0.72;
  const RIDGE_AMP = [0.06, 0.03, 0.015];
  const CLOUD_BAND = 0.12;
  const CLOUD_THRESHOLD = 0.45;
  const CENTER_SUPPRESS = 0.45;

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  type Zone = 'sky' | 'cloud' | 'mountain';

  interface CharCell {
    x: number;
    y: number;
    phase: number;
    baseOpacity: number;
    r: number;
    g: number;
    b: number;
    zone: Zone;
    colorStr: string;
  }

  let cells: CharCell[] = [];
  let mouseX = -9999;
  let mouseY = -9999;
  let mouseActive = false;
  let animId = 0;
  let isVisible = true;
  let canvasW = 0;
  let canvasH = 0;

  // Procedural ridgeline — 3 layered sine waves per column
  function ridgelineAt(col: number, totalCols: number): number {
    const nx = col / totalCols;
    return RIDGE_BASE
      + Math.sin(nx * Math.PI * 2.3 + 0.8) * RIDGE_AMP[0]
      + Math.sin(nx * Math.PI * 5.1 + 2.1) * RIDGE_AMP[1]
      + Math.sin(nx * Math.PI * 11.7 + 4.3) * RIDGE_AMP[2];
  }

  // Cloud clumpiness via cheap sine noise
  function cloudNoise(col: number, row: number): number {
    return (Math.sin(col * 0.7 + row * 1.3) * 0.5 + 0.5)
      * (Math.cos(col * 1.1 - row * 0.9 + 2.7) * 0.5 + 0.5);
  }

  // Linear interpolation helper
  function lerp(a: number, b: number, t: number): number {
    return a + (b - a) * t;
  }

  function buildGrid() {
    cells = [];
    canvasW = canvas!.width / DPR;
    canvasH = canvas!.height / DPR;
    const cols = Math.ceil(canvasW / GRID_SPACING) + 1;
    const rows = Math.ceil(canvasH / GRID_SPACING) + 1;
    const cx = canvasW / 2;
    const cy = canvasH / 2;

    for (let r = 0; r < rows; r++) {
      for (let c = 0; c < cols; c++) {
        const x = c * GRID_SPACING;
        const y = r * GRID_SPACING;
        const ny = r / rows; // normalized Y (0 = top, 1 = bottom)
        const ridge = ridgelineAt(c, cols);
        const cloudTop = ridge - CLOUD_BAND;

        // Zone classification
        let zone: Zone;
        let cr: number, cg: number, cb: number;
        let base: number;

        // Smooth blend: 0 = pure sky, 1 = pure mountain
        const FADE_BAND = 0.06;
        const blendCenter = (cloudTop + ridge) / 2;
        const blendHalf = Math.max((ridge - cloudTop) / 2 + FADE_BAND, 0.01);
        const rawBlend = (ny - blendCenter + blendHalf) / (blendHalf * 2);
        const cb2 = Math.max(0, Math.min(rawBlend, 1));
        const blend = cb2 * cb2 * (3 - 2 * cb2); // smoothstep

        // Sky: warm peach
        const skyT = Math.min(ny / Math.max(cloudTop, 0.01), 1);
        const skyR = lerp(248, 240, skyT);
        const skyG = lerp(220, 195, skyT);
        const skyB = lerp(195, 170, skyT);

        // Mountain: warm peach-orange → burnt orange (brand-aligned)
        const mtnDepth = Math.min(Math.max(0, (ny - ridge) / Math.max(1 - ridge, 0.01)), 1);
        const mtnR = lerp(238, 200, mtnDepth);
        const mtnG = lerp(150, 105, mtnDepth);
        const mtnB = lerp(90, 55, mtnDepth);

        cr = Math.round(lerp(skyR, mtnR, blend));
        cg = Math.round(lerp(skyG, mtnG, blend));
        cb = Math.round(lerp(skyB, mtnB, blend));

        // High contrast: nearly invisible sky, bold mountains
        const skyBase = 0.02 + Math.random() * 0.02;
        const mtnBase = 0.25 + Math.random() * 0.10;
        base = lerp(skyBase, mtnBase, blend);

        if (blend < 0.3) {
          zone = 'sky';
        } else if (blend > 0.7) {
          zone = 'mountain';
        } else {
          zone = 'cloud';
        }

        // Center suppression — smooth radial fade for text readability
        const dist = Math.sqrt((x - cx) ** 2 + ((y - cy) * 1.4) ** 2); // elliptical, wider than tall
        const innerR = Math.min(cx, cy) * 0.2;
        const outerR = Math.min(cx, cy) * 0.55;
        if (dist < outerR) {
          const t = Math.max(0, (dist - innerR) / (outerR - innerR));
          const fade = t * t; // ease-in: fully suppressed at center, smooth ramp out
          base *= CENTER_SUPPRESS + (1 - CENTER_SUPPRESS) * fade;
        }

        cells.push({
          x,
          y,
          phase: Math.random() * Math.PI * 2,
          baseOpacity: base,
          r: cr,
          g: cg,
          b: cb,
          zone,
          colorStr: `rgb(${cr},${cg},${cb})`,
        });
      }
    }
  }

  function resize() {
    const dims = sizeCanvasToParent(canvas!, ctx!, DPR);
    canvasW = dims.w;
    canvasH = dims.h;
    buildGrid();
  }

  function drawStatic() {
    ctx!.clearRect(0, 0, canvasW, canvasH);

    for (const cell of cells) {
      ctx!.globalAlpha = cell.baseOpacity;
      ctx!.fillStyle = cell.colorStr;
      ctx!.beginPath();
      ctx!.arc(cell.x, cell.y, DOT_RADIUS, 0, Math.PI * 2);
      ctx!.fill();
    }
    ctx!.globalAlpha = 1;
  }

  function animate(time: number) {
    if (document.hidden) {
      animId = requestAnimationFrame(animate);
      return;
    }

    ctx!.clearRect(0, 0, canvasW, canvasH);

    const t = time * 0.001;

    // Two wandering attractors — always running, Lissajous paths at different speeds
    const { at1X, at1Y, at2X, at2Y } = getAttractorPositions(t, canvasW, canvasH);

    for (const cell of cells) {
      // Ambient breathing — gentle opacity pulse
      const breath = Math.sin(t * 0.6 + cell.phase) * 0.03;
      let opacity = cell.baseOpacity + breath;

      // Attractor 1 — wandering glow (opacity only)
      {
        const adx = cell.x - at1X;
        const ady = cell.y - at1Y;
        const adistSq = adx * adx + ady * ady;
        if (adistSq < ATTRACTOR_RADIUS * ATTRACTOR_RADIUS) {
          const ratio = 1 - (Math.sqrt(adistSq) / ATTRACTOR_RADIUS);
          const ease = ratio * ratio;
          opacity = opacity + (0.28 - opacity) * ease;
        }
      }

      // Attractor 2 — secondary wandering glow (opacity only)
      {
        const adx = cell.x - at2X;
        const ady = cell.y - at2Y;
        const adistSq = adx * adx + ady * ady;
        const a2r = ATTRACTOR_RADIUS * 0.8;
        if (adistSq < a2r * a2r) {
          const ratio = 1 - (Math.sqrt(adistSq) / a2r);
          const ease = ratio * ratio;
          opacity = opacity + (0.22 - opacity) * ease * 0.6;
        }
      }

      // Cursor interaction — opacity boost only
      if (mouseActive) {
        const cdx = cell.x - mouseX;
        const cdy = cell.y - mouseY;
        const cdistSq = cdx * cdx + cdy * cdy;
        if (cdistSq < CURSOR_RADIUS * CURSOR_RADIUS) {
          const ratio = 1 - (Math.sqrt(cdistSq) / CURSOR_RADIUS);
          const ease = ratio * ratio;
          opacity = opacity + (0.35 - opacity) * ease;
        }
      }

      ctx!.globalAlpha = Math.max(0.02, Math.min(opacity, 0.35));
      ctx!.fillStyle = cell.colorStr;
      ctx!.beginPath();
      ctx!.arc(cell.x, cell.y, DOT_RADIUS, 0, Math.PI * 2);
      ctx!.fill();
    }

    ctx!.globalAlpha = 1;
    animId = isVisible ? requestAnimationFrame(animate) : 0;
  }

  // Mouse tracking
  attachMouseTracker(
    canvas.closest('section')!,
    canvas,
    (x, y) => { mouseX = x; mouseY = y; mouseActive = true; },
    () => { mouseActive = false; }
  );

  // Init
  resize();

  const heroObs = new IntersectionObserver((entries) => {
    isVisible = entries[0].isIntersecting;
    if (isVisible && !prefersReducedMotion && animId === 0) animId = requestAnimationFrame(animate);
    else if (!isVisible) { cancelAnimationFrame(animId); animId = 0; }
  }, { threshold: 0 });
  heroObs.observe(canvas!.closest('section')!);

  if (prefersReducedMotion) {
    drawStatic();
  } else {
    animId = requestAnimationFrame(animate);
  }

  attachResizeHandler(() => {
    resize();
    if (prefersReducedMotion) drawStatic();
  });
  })();
</script>
