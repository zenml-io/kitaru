---
// Hero.astro — Hero section with side-by-side layout + tabbed code
---

<section class="hero-section" style="padding: 120px clamp(24px, 5vw, 80px) 80px;">
  <div class="section-inner">
    <div class="hero-grid">
      <!-- Left: copy + CTA -->
      <div class="hero-left">
        <div class="hero-badge" data-reveal>
          <span class="dot"></span>
          From the makers of <a href="https://zenml.io" target="_blank" rel="noopener" style="color: inherit; text-decoration: underline; text-underline-offset: 2px;">ZenML</a> — early access March 2026
        </div>

        <h1
          style="font-weight: 700; font-size: clamp(2.4rem, 5vw, 3.8rem); line-height: 1.08; letter-spacing: -0.03em; margin-bottom: 24px;"
          data-reveal data-reveal-delay="1"
        >
          Agents get harder as they grow.<br>Infrastructure <em class="gradient-text" style="font-style: normal;">shouldn't.</em>
        </h1>

        <p
          style="font-size: clamp(1rem, 1.8vw, 1.15rem); max-width: 480px; line-height: 1.65; margin-bottom: 36px; font-weight: 300; color: var(--color-secondary);"
          data-reveal data-reveal-delay="2"
        >
          Durable execution, <strong style="font-weight: 500; color: var(--color-primary);">input gates</strong>, and crash recovery for Python agents.
        </p>

        <div data-reveal data-reveal-delay="3">
          <a href="#schedule-demo" class="hero-cta-btn">Schedule a Demo</a>
          <p style="font-size: 0.75rem; margin-top: 12px; color: var(--color-muted);">Open source. Free to start. No credit card required.</p>
        </div>
      </div>

      <!-- Right: tabbed code snippet -->
      <div class="hero-right" data-reveal data-reveal-delay="3">
        <div class="code-window hero-code-window">
          <div class="code-header">
            <span class="code-dot"></span>
            <span class="code-dot"></span>
            <span class="code-dot"></span>
            <div class="code-tabs">
              <button class="code-tab active" data-tab="plain">Plain Python</button>
              <button class="code-tab" data-tab="framework">With a framework</button>
            </div>
          </div>
          <!-- Plain Python tab -->
          <div class="code-tab-content active" id="tab-plain">
            <pre class="code-pre"><code><span class="kw">import</span> kitaru
<span class="kw">from</span> kitaru <span class="kw">import</span> flow

<span class="dec">@flow</span>
<span class="kw">def</span> <span class="fn">coding_agent</span>(issue: <span class="var">str</span>) <span class="op">-></span> <span class="var">str</span>:
    plan <span class="op">=</span> <span class="fn">analyze_issue</span>(issue)    <span class="cmt"># cached on replay</span>
    patch <span class="op">=</span> <span class="fn">write_code</span>(plan)      <span class="cmt"># cached on replay</span>

    <span class="cmt"># Pauses. Resumes when input arrives.</span>
    approved <span class="op">=</span> kitaru.<span class="fn">wait</span>(<span class="var">bool</span>, question<span class="op">=</span><span class="str">"Merge this PR?"</span>)
    <span class="kw">if</span> approved:
        <span class="fn">merge</span>(patch)
    <span class="kw">return</span> patch

<span class="cmt"># Replay — completed steps are cached.</span>
coding_agent.<span class="fn">replay</span>(exec_id<span class="op">=</span><span class="str">"kr-a8f3c2"</span>, issue<span class="op">=</span><span class="str">"New bug"</span>)
<span class="cmt"># Same code, any infra.</span>
coding_agent.<span class="fn">deploy</span>(<span class="str">"Fix login bug"</span>, stack<span class="op">=</span><span class="str">"aws-sandbox"</span>)</code></pre>
          </div>
          <!-- Framework tab -->
          <div class="code-tab-content" id="tab-framework">
            <pre class="code-pre"><code><span class="kw">from</span> kitaru <span class="kw">import</span> flow
<span class="kw">from</span> kitaru.adapters <span class="kw">import</span> pydantic_ai <span class="kw">as</span> kp

<span class="cmt"># Every LLM call + tool use is checkpointed.</span>
<span class="cmt"># Approval happens inside the agent loop.</span>
coder <span class="op">=</span> kp.<span class="fn">wrap</span>(Agent(<span class="str">"claude-sonnet-4-6"</span>, tools<span class="op">=</span>[edit, test, approve]))

<span class="dec">@flow</span>
<span class="kw">def</span> <span class="fn">coding_agent</span>(issue: <span class="var">str</span>) <span class="op">-></span> <span class="var">str</span>:
    <span class="kw">return</span> coder.<span class="fn">run_sync</span>(<span class="str">f"Fix: </span>{'{'}issue{'}'}<span class="str">"</span>).output

<span class="cmt"># Replay — completed steps are cached.</span>
coding_agent.<span class="fn">replay</span>(exec_id<span class="op">=</span><span class="str">"kr-b7e4d1"</span>, issue<span class="op">=</span><span class="str">"New bug"</span>)
<span class="cmt"># Same code, any infra.</span>
coding_agent.<span class="fn">deploy</span>(<span class="str">"Fix login bug"</span>, stack<span class="op">=</span><span class="str">"gcp-production"</span>)</code></pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 60px;
    align-items: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px 6px 8px;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    font-size: 0.8rem;
    color: var(--color-secondary);
    margin-bottom: 28px;
    background: var(--color-surface);
  }

  .hero-badge .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(241,120,41,0.4); }
    50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(241,120,41,0); }
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-deep) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-cta-btn {
    display: inline-block;
    padding: 14px 32px;
    background: var(--color-primary);
    color: #fff;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: all 0.25s;
    white-space: nowrap;
    font-family: var(--font-ui);
    text-decoration: none;
  }

  .hero-cta-btn:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  /* Code window */
  .code-window {
    background: #1A1714;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 40px rgba(26,23,20,0.12);
  }

  .code-header {
    display: flex;
    align-items: center;
    padding: 12px 16px;
    gap: 8px;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    background: rgba(26,23,20,0.95);
  }

  .code-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .code-dot:nth-child(1) { background: #E85540; }
  .code-dot:nth-child(2) { background: #E8A840; }
  .code-dot:nth-child(3) { background: #40C840; }

  .code-pre {
    margin: 0;
    padding: 24px 28px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.75;
    color: #E8E4DE;
    overflow-x: auto;
    background: transparent;
  }

  .code-pre code {
    font-family: inherit;
  }

  .code-pre .kw { color: #C792EA; }
  .code-pre .fn { color: #82AAFF; }
  .code-pre .str { color: #C3E88D; }
  .code-pre .var { color: #F78C6C; }
  .code-pre .op { color: #89DDFF; }
  .code-pre .num { color: #F78C6C; }
  .code-pre .dec { color: #FFCB6B; }
  .code-pre .cmt { color: #546E7A; font-style: italic; }

  /* Tabs */
  .code-tabs {
    display: flex;
    gap: 0;
    margin-left: auto;
  }

  .code-tab {
    background: none;
    border: none;
    padding: 4px 14px;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: rgba(255,255,255,0.35);
    cursor: pointer;
    border-radius: 4px;
    transition: all 0.2s;
  }

  .code-tab:hover {
    color: rgba(255,255,255,0.6);
  }

  .code-tab.active {
    background: rgba(241,120,41,0.15);
    color: #F17829;
  }

  .code-tab-content {
    display: none;
  }

  .code-tab-content.active {
    display: block;
  }

  .hero-code-window {
    width: 100%;
  }

  .code-filename {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: rgba(255,255,255,0.35);
    margin-left: 12px;
  }

  .divider-line {
    height: 1px;
    background: var(--color-border-light);
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .hero-section {
      padding-top: 80px !important;
      padding-bottom: 60px !important;
    }

  }

  @media (max-width: 900px) {
    .hero-left, .hero-right {
      min-width: 0;
      overflow: hidden;
    }
  }

  @media (max-width: 480px) {
    .hero-section {
      padding-top: 72px !important;
      padding-bottom: 40px !important;
    }

    .hero-grid { gap: 28px; }

    .hero-badge { font-size: 0.7rem; margin-bottom: 20px; }

    .code-pre {
      font-size: 0.7rem;
      padding: 16px 14px;
      line-height: 1.6;
    }

    .code-tab { font-size: 0.62rem; padding: 3px 10px; }
  }
</style>

<script>
  // Tab switching — scoped to hero code window
  const heroWindow = document.querySelector('.hero-code-window');
  heroWindow?.querySelectorAll('.code-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      heroWindow.querySelectorAll('.code-tab').forEach(t => t.classList.remove('active'));
      heroWindow.querySelectorAll('.code-tab-content').forEach(c => c.classList.remove('active'));
      tab.classList.add('active');
      const target = tab.getAttribute('data-tab');
      document.getElementById(`tab-${target}`)?.classList.add('active');
    });
  });

</script>
