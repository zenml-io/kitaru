---
import Base from './Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import TableOfContents from '../components/blog/TableOfContents.astro';
import BlogBottomCTA from '../components/blog/BlogBottomCTA.astro';
import { AUTHORS, CATEGORY_STYLES } from '../lib/blog';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  date: Date;
  author: string;
  category?: string;
  ogImage?: string;
  image?: string;
  readTime: string;
  relatedPosts?: { href: string; title: string; author: string; readTime: string }[];
  headings?: Heading[];
}

const {
  title,
  description,
  date,
  author,
  category = 'Agents',
  ogImage,
  image,
  readTime,
  relatedPosts = [],
  headings = [],
} = Astro.props;

const formatted = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
}).format(date);

const isoDate = date.toISOString();
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const authorData = AUTHORS[author] ?? { initials: '??', color: '#9E9790' };
const catStyle = CATEGORY_STYLES[category] ?? CATEGORY_STYLES.Agents;
const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site).href
  : 'https://assets.kitaru.ai/content/site/dee725d9/kitaru-og.png';
---

<Base title={`${title} — Kitaru Blog`} description={description} ogImage={ogImageUrl}>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="article:published_time" content={isoDate} />
    <meta property="article:author" content={author} />
    <meta property="article:tag" content={category} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
  </Fragment>
  <Nav />
  <main id="main-content">
    <article class="blog-post" itemscope itemtype="https://schema.org/BlogPosting">
      <meta itemprop="datePublished" content={isoDate} />
      <meta itemprop="author" content={author} />

      <!-- Hero header -->
      <header class="blog-post-hero">
        <div class="blog-post-hero-inner">
          <a href="/blog" class="blog-back">&larr; Blog</a>
          <div class="blog-post-top">
            <span class="cat-pill" style={`background:${catStyle.bg};color:${catStyle.color};`}>{category}</span>
            <span class="blog-post-read-time">{readTime}</span>
          </div>
          <h1 class="blog-post-title" itemprop="headline">{title}</h1>
          <div class="blog-post-author">
            {authorData.image ? (
              <img class="avatar" src={authorData.image} alt={author} />
            ) : (
              <span class="avatar" style={`background:${authorData.color};`}>{authorData.initials}</span>
            )}
            <div class="blog-post-author-info">
              <span class="blog-post-author-name">{author}</span>
              <time datetime={isoDate} class="blog-post-author-date">{formatted}</time>
            </div>
          </div>
        </div>
      </header>

      <!-- Hero image -->
      {image && (
        <div class="blog-post-image-wrap">
          <img src={image} alt={title} class="blog-post-image" itemprop="image" />
        </div>
      )}

      <!-- Body + TOC sidebar -->
      <div class="blog-post-body-wrap">
        <TableOfContents headings={headings} />
        <div class="blog-post-body" itemprop="articleBody">
          <slot />
        </div>
      </div>
    </article>

    <!-- Bottom CTA — mirrors body-wrap flex layout to align with prose column -->
    <div class="blog-prose-align">
      <div class="blog-prose-align-spacer" aria-hidden="true"></div>
      <div class="blog-prose-align-content">
        <BlogBottomCTA />
      </div>
    </div>

    <!-- Related posts -->
    {relatedPosts.length > 0 && (
      <div class="blog-prose-align">
        <div class="blog-prose-align-spacer" aria-hidden="true"></div>
        <section class="blog-prose-align-content blog-related">
          <h4 class="blog-related-heading">Continue reading</h4>
          <div class="blog-related-grid">
            {relatedPosts.map((rp) => (
              <a class="blog-related-card" href={rp.href}>
                <h5>{rp.title}</h5>
                <span>{rp.author} &middot; {rp.readTime}</span>
              </a>
            ))}
          </div>
        </section>
      </div>
    )}
  </main>
  <Footer />
</Base>

<style>
  /* ── Hero header ── */
  .blog-post-hero {
    background: rgba(250,250,248,0.8);
    padding: 56px clamp(16px, 5vw, 80px) 40px;
    margin-bottom: 32px;
    border-bottom: 1px solid var(--color-border-light);
  }

  .blog-post-hero-inner {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .blog-back {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.2s;
    margin-bottom: 4px;
  }

  .blog-back:hover {
    color: var(--color-accent);
  }

  .blog-post-top {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .cat-pill {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 3px 9px;
    border-radius: 4px;
    line-height: 1;
  }

  .blog-post-read-time {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .blog-post-title {
    font-size: clamp(1.6rem, 4vw, 2.6rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-primary);
    margin: 0;
  }

  .blog-post-author {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 4px;
  }

  .avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 600;
    color: #fff;
    flex-shrink: 0;
    object-fit: cover;
  }

  .blog-post-author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .blog-post-author-name {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-primary);
  }

  .blog-post-author-date {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-muted);
  }

  /* ── Hero image ── */
  .blog-post-image-wrap {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 clamp(16px, 5vw, 80px);
  }

  .blog-post-image {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: 10px;
    display: block;
    border: 1px solid var(--color-border);
  }

  /* ── Body + TOC wrapper ── */
  .blog-post-body-wrap {
    --toc-width: 220px;
    --toc-gap: 48px;
    max-width: 1060px;
    margin: 0 auto;
    padding: 48px clamp(16px, 5vw, 48px) 60px;
    display: flex;
    justify-content: center;
  }

  .blog-post-body {
    max-width: 720px;
    width: 100%;
    min-width: 0;
    font-size: clamp(0.95rem, 2.5vw, 1.05rem);
    line-height: 1.75;
    color: var(--color-secondary);
  }

  .blog-post-body :global(h2) {
    font-size: clamp(1.2rem, 3vw, 1.4rem);
    font-weight: 600;
    color: var(--color-primary);
    margin: 48px 0 16px;
    letter-spacing: -0.01em;
    scroll-margin-top: 80px;
  }

  .blog-post-body :global(h3) {
    font-size: clamp(1.1rem, 2.5vw, 1.22rem);
    font-weight: 600;
    color: var(--color-primary);
    margin: 36px 0 12px;
    letter-spacing: -0.01em;
  }

  .blog-post-body :global(p) {
    margin: 0 0 20px;
  }

  .blog-post-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .blog-post-body :global(strong) {
    font-weight: 600;
    color: var(--color-primary);
  }

  .blog-post-body :global(em) {
    font-style: italic;
  }

  .blog-post-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.85em;
    color: var(--color-accent);
    background: rgba(241, 120, 41, 0.08);
    padding: 2px 6px;
    border-radius: 4px;
    word-break: break-word;
  }

  .blog-post-body :global(pre) {
    background: #F0EBE3;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 16px 20px;
    overflow-x: auto;
    margin: 24px -16px;
  }

  .blog-post-body :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.82rem;
    color: #3D3530;
    line-height: 1.55;
    word-break: normal;
  }

  .blog-post-body :global(ul),
  .blog-post-body :global(ol) {
    margin: 0 0 20px;
    padding-left: 24px;
  }

  .blog-post-body :global(li) {
    margin-bottom: 8px;
  }

  .blog-post-body :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: 20px;
    margin: 24px 0;
    color: var(--color-muted);
    font-style: italic;
  }

  .blog-post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 40px 0;
  }

  .blog-post-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 24px 0;
    font-size: 0.88rem;
    overflow-x: auto;
    display: block;
  }

  .blog-post-body :global(th),
  .blog-post-body :global(td) {
    padding: 10px 14px;
    border: 1px solid var(--color-border);
    text-align: left;
  }

  .blog-post-body :global(th) {
    font-weight: 600;
    color: var(--color-primary);
    background: var(--color-surface-warm);
  }

  /* ── Prose-column alignment utility ── */
  .blog-prose-align {
    --toc-width: 220px;
    --toc-gap: 48px;
    max-width: 1060px;
    margin: 0 auto;
    padding: 0 clamp(16px, 5vw, 48px);
    display: flex;
    justify-content: center;
  }

  .blog-prose-align-spacer {
    width: var(--toc-width);
    flex-shrink: 0;
    margin-right: var(--toc-gap);
  }

  .blog-prose-align-content {
    max-width: 720px;
    width: 100%;
    min-width: 0;
  }

  @media (max-width: 1100px) {
    .blog-prose-align-spacer {
      display: none;
    }
  }

  /* ── Related posts ── */
  .blog-related {
    border-top: 1px solid var(--color-border-light);
    padding-top: 40px;
    padding-bottom: 80px;
    margin-top: 48px;
  }

  .blog-related-heading {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 20px;
  }

  .blog-related-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .blog-related-card {
    padding: 20px;
    border-radius: 8px;
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s;
  }

  .blog-related-card:hover,
  .blog-related-card:focus-visible {
    border-color: rgba(241, 120, 41, 0.3);
  }

  .blog-related-card h5 {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 6px;
    line-height: 1.4;
  }

  .blog-related-card span {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    color: var(--color-muted);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .blog-related-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .blog-post-hero {
      padding-top: 32px;
      padding-bottom: 28px;
    }

    .blog-post-body-wrap {
      padding-top: 32px;
      padding-bottom: 40px;
    }

    .blog-post-body :global(pre) {
      margin-left: -16px;
      margin-right: -16px;
      border-radius: 0;
    }
  }
</style>
