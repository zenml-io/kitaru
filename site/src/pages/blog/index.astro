---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import BlogCard from '../../components/blog/BlogCard.astro';
import { readingTime, AUTHORS, CATEGORY_STYLES } from '../../lib/blog';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const [featured, ...rest] = posts;

const featuredDate = new Intl.DateTimeFormat('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
}).format(featured.data.date);

const featuredAuthor = AUTHORS[featured.data.author] ?? { initials: '??', color: '#9E9790' };
const featuredCategory = featured.data.category ?? 'Agents';
const featuredCatStyle = CATEGORY_STYLES[featuredCategory] ?? CATEGORY_STYLES.Agents;
const featuredReadTime = readingTime(featured.body ?? '');
---

<Base title="Blog — Kitaru" description="Thoughts on durable execution, agent infrastructure, and building reliable AI systems.">
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL('/blog', Astro.site).href} />
  </Fragment>
  <Nav />
  <main class="blog-index">
    <div class="section-inner">
      <span class="section-eyebrow" data-reveal>Blog</span>
      <p class="blog-subtitle" data-reveal data-reveal-delay="1">Thoughts on durable execution, agent infrastructure, and building reliable AI systems.</p>

      <!-- Featured post -->
      <a href={`/blog/${featured.id}`} class="blog-featured" data-reveal data-reveal-delay="2">
        <div class="blog-featured-content">
          <div class="blog-featured-top">
            <span class="cat-pill" style={`background:${featuredCatStyle.bg};color:${featuredCatStyle.color};`}>{featuredCategory}</span>
            <span class="blog-meta-text">{featuredReadTime}</span>
          </div>
          <div class="blog-featured-author">
            {featuredAuthor.image ? (
              <img class="avatar" src={featuredAuthor.image} alt={featured.data.author} />
            ) : (
              <span class="avatar" style={`background:${featuredAuthor.color};`}>{featuredAuthor.initials}</span>
            )}
            <span class="blog-meta-text">{featured.data.author} &middot; {featuredDate}</span>
          </div>
          <h1 class="blog-featured-title">{featured.data.title}</h1>
          <p class="blog-featured-desc">{featured.data.description}</p>
          <span class="blog-featured-read">Read post &rarr;</span>
        </div>
        <div class="blog-featured-image" aria-hidden="true">
          {featured.data.image ? (
            <img src={featured.data.image} alt={featured.data.title} class="blog-featured-img" />
          ) : (
            <div class="blog-featured-image-inner"></div>
          )}
        </div>
      </a>

      <!-- Remaining posts -->
      {rest.length > 0 && (
        <div class="blog-grid" data-reveal data-reveal-delay="3">
          {rest.map((post) => (
            <BlogCard
              href={`/blog/${post.id}`}
              title={post.data.title}
              description={post.data.description}
              date={post.data.date}
              author={post.data.author}
              category={post.data.category}
              body={post.body ?? ''}
              image={post.data.image}
            />
          ))}
        </div>
      )}
    </div>
  </main>
  <Footer />
</Base>

<style>
  .blog-index {
    padding: 40px clamp(16px, 5vw, 80px) 100px;
  }

  .blog-subtitle {
    font-size: clamp(0.88rem, 2vw, 0.95rem);
    color: var(--color-secondary);
    line-height: 1.5;
    max-width: 480px;
    margin-bottom: 32px;
  }

  /* ── Featured post ── */
  .blog-featured {
    display: grid;
    grid-template-columns: 1fr 1fr;
    text-decoration: none;
    border-radius: 14px;
    border: 1px solid var(--color-border);
    background: linear-gradient(135deg, rgba(241, 120, 41, 0.06) 0%, rgba(160, 120, 72, 0.05) 100%);
    overflow: hidden;
    margin-bottom: 48px;
    transition: border-color 0.2s, transform 0.15s;
  }

  .blog-featured:hover {
    border-color: rgba(241, 120, 41, 0.35);
    transform: translateY(-2px);
  }

  .blog-featured-content {
    padding: clamp(28px, 5vw, 44px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 12px;
  }

  .blog-featured-top {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .blog-featured-author {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .blog-featured-title {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--color-primary);
    margin: 0;
  }

  .blog-featured-desc {
    font-size: clamp(0.9rem, 2vw, 1rem);
    line-height: 1.6;
    color: var(--color-secondary);
    margin: 0;
    max-width: 560px;
  }

  .blog-featured-read {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 500;
    color: var(--color-accent);
    margin-top: 4px;
  }

  .blog-featured-image {
    aspect-ratio: 16 / 9;
    position: relative;
    overflow: hidden;
  }

  .blog-featured-image-inner {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(241, 120, 41, 0.1) 0%, rgba(160, 120, 72, 0.12) 60%, rgba(26, 23, 20, 0.04) 100%);
  }

  .blog-featured-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Shared meta styles ── */
  .cat-pill {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 4px;
    line-height: 1;
  }

  .blog-meta-text {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .avatar {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 600;
    color: #fff;
    flex-shrink: 0;
    object-fit: cover;
  }

  /* ── Grid (2-column) ── */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  @media (max-width: 900px) {
    .blog-featured {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .blog-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .blog-index {
      padding-bottom: 60px;
    }

    .blog-featured {
      margin-bottom: 36px;
    }
  }
</style>
