---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Primitives from '../components/Primitives.astro';
import Architecture from '../components/Architecture.astro';
import Credibility from '../components/Credibility.astro';
import CodingAgent from '../components/CodingAgent.astro';
import Features from '../components/Features.astro';
import AgentNative from '../components/AgentNative.astro';
import Cta from '../components/Cta.astro';
import Footer from '../components/Footer.astro';
---

<Base>
  <Nav />
  <main>
    <!-- 1. Hero -->
    <Hero />
    <div class="gradient-divider"></div>
    <!-- 2. Primitives -->
    <Primitives />
    <div class="gradient-divider"></div>
    <!-- 3. Architecture -->
    <Architecture />
    <div class="gradient-divider"></div>
    <!-- 4. Credibility -->
    <Credibility />
    <div class="gradient-divider"></div>
    <!-- 5. Coding Agent timeline -->
    <CodingAgent />
    <div class="gradient-divider"></div>
    <!-- 6. Features (animated cards) -->
    <Features />
    <div class="gradient-divider"></div>
    <!-- 6. Agent-native (MCP) -->
    <AgentNative />
    <div class="gradient-divider"></div>
    <!-- 7. CTA -->
    <Cta />
  </main>
  <Footer />
</Base>
