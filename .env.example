# -------------------------------------------------------------------
# Kitaru — Environment Variables
#
# Copy this file to .env and fill in your values.
# The .env file is gitignored and safe for secrets.
#
# NOTE: The site BUILD does not require any env vars.
# These are only needed for image upload tooling.
# -------------------------------------------------------------------

# -------------------------------------------------------------------
# Cloudflare R2 (image/asset uploads)
# -------------------------------------------------------------------

# Cloudflare account ID (find at: dash.cloudflare.com → Overview → right sidebar)
CLOUDFLARE_ACCOUNT_ID=

# R2 bucket name
R2_BUCKET=kitaru-assets

# R2 API token credentials (create at: dash.cloudflare.com → R2 → Manage R2 API Tokens)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Public base URL for uploaded assets (custom domain on the R2 bucket)
R2_PUBLIC_BASE_URL=https://assets.kitaru.ai
